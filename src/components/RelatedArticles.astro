---
interface Article {
  title: string;
  href: string;
  category: string;
  readTime: string;
}
interface Props {
  articles: Article[];
}
const { articles } = Astro.props;
---
<section class="pb-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
      </div>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Похожие статьи</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {articles.map((a) => (
        <a href={a.href} class="glass-card p-5 flex flex-col group hover:-translate-y-1 transition-transform">
          <span class="inline-block px-2.5 py-0.5 rounded-full bg-white/5 text-[11px] font-medium text-accent border border-white/10 self-start mb-3">{a.category}</span>
          <h3 class="text-white font-bold text-[15px] leading-snug mb-auto group-hover:text-accent transition-colors">{a.title}</h3>
          <span class="mt-4 pt-3 border-t border-white/10 text-xs text-muted-foreground flex items-center gap-1.5">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {a.readTime}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
