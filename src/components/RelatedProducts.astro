---
interface Product {
  name: string;
  href: string;
  desc: string;
  tag: string;
}
interface Props {
  products: Product[];
}
const { products } = Astro.props;
---
<section class="pb-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
      </div>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Решения AZONE-AI по теме</h2>
    </div>
    <div class={`grid gap-5 ${products.length === 1 ? 'grid-cols-1 max-w-sm' : 'grid-cols-1 md:grid-cols-2'}`}>
      {products.map((p) => (
        <a href={p.href} class="glass-card p-5 flex flex-col group hover:-translate-y-1 transition-transform">
          <span class="inline-block px-2.5 py-0.5 rounded-full bg-primary/10 text-[11px] font-medium text-primary border border-primary/20 self-start mb-3">{p.tag}</span>
          <h3 class="text-white font-bold text-[15px] leading-snug mb-2 group-hover:text-accent transition-colors">{p.name}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed flex-grow">{p.desc}</p>
          <span class="mt-4 pt-3 border-t border-white/10 text-xs text-primary font-medium flex items-center gap-1.5 group-hover:text-accent transition-colors">
            Подробнее о продукте
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
