---
import Base from '../layouts/Base.astro';
---
<Base
  title="Поиск по сайту"
  description="Поиск по статьям, продуктам и страницам AZONE-AI."
  pagefindIgnore={true}
>
  <section class="pt-28 pb-20 border-b border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-accent transition-colors mb-8">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        На главную
      </a>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">Поиск по сайту</h1>
      <p class="text-lg text-muted-foreground">
        Ищите статьи, продукты и материалы по ключевым словам.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card p-6 md:p-8">
        <div id="search-ui"></div>
      </div>
      <p class="text-xs text-muted-foreground mt-4">
        Подсказка: попробуйте запросы «on-premise», «КИИ», «AzoneDoc», «LLM», «предиктивная аналитика».
      </p>
    </div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const target = document.querySelector('#search-ui');
      if (!target || !window.PagefindUI) return;
      const initialQuery = new URLSearchParams(window.location.search).get('q')?.trim();

      const applyInitialQuery = () => {
        if (!initialQuery) return;
        const input = document.querySelector('.pagefind-ui__search-input');
        if (!input) return false;
        input.value = initialQuery;
        input.dispatchEvent(new Event('input', { bubbles: true }));
        return true;
      };

      // Pagefind indexes static HTML at build time and runs fully client-side.
      new window.PagefindUI({
        element: '#search-ui',
        showSubResults: true,
        resetStyles: false,
        highlightParam: 'q',
        translations: {
          placeholder: 'Введите запрос...',
          clear_search: 'Очистить',
          load_more: 'Показать ещё',
          search_label: 'Поиск по сайту',
          zero_results: 'Ничего не найдено',
          many_results: '[COUNT] результатов',
          one_result: '[COUNT] результат',
        },
      });

      if (initialQuery) {
        let attempts = 0;
        const timer = window.setInterval(() => {
          attempts += 1;
          if (applyInitialQuery() || attempts > 20) {
            window.clearInterval(timer);
          }
        }, 100);
      }
    });
  </script>

  <style>
    #search-ui :global(.pagefind-ui__search-input) {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: #fff;
      border-radius: 12px;
      min-height: 48px;
    }
    #search-ui :global(.pagefind-ui__result-title a) { color: #fff; }
    #search-ui :global(.pagefind-ui__result-link) { color: #22d3ee; }
  </style>
</Base>
