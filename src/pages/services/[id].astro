---
import Base from '../../layouts/Base.astro';
import PilotCostCalculator from '../../components/PilotCostCalculator.astro';
import { services } from '../../data/services.js';
import { products } from '../../data/products.js';

export function getStaticPaths() {
  return services.map((s) => ({ params: { id: s.id }, props: { service: s } }));
}

const { service } = Astro.props;
const relatedProductCards = service.relatedProducts
  .map((pid) => products.find((p) => p.id === pid))
  .filter(Boolean);
const serviceFaq = service.faq || [];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  serviceType: service.serviceType,
  description: service.pageDescription,
  url: `https://azoneai.ru/services/${service.id}/`,
  areaServed: { '@type': 'Country', name: 'RU' },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'B2B, B2G, критическая инфраструктура',
  },
  provider: {
    '@type': 'Organization',
    name: 'AZONE-AI',
    url: 'https://azoneai.ru',
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'RUB',
    priceRange: service.pricing.priceRangeSchema,
    availability: 'https://schema.org/InStock',
  },
};

const contactBase = `/contact/?service=${service.id}`;
---

<Base
  title={service.pageTitle}
  description={service.pageDescription}
  breadcrumbTitle={service.name}
  image={`/images/og/service-${service.id}.jpg`}
>

  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
  {serviceFaq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: serviceFaq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      })),
    })} />
  )}

  <!-- Hero -->
  <section class="relative pt-24 py-20 overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <a href="/services/" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-accent transition-colors mb-12">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Назад к услугам
      </a>
      <div class="max-w-4xl animate-fade-up">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white mb-6">
          <span class="font-heading font-medium tracking-wider">УСЛУГА {service.number}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-heading font-bold text-white mb-6 leading-tight">
          {service.h1.includes(service.h1Gradient) ? (
            <>
              {service.h1.split(service.h1Gradient)[0]}
              <span class="text-gradient">{service.h1Gradient}</span>
              {service.h1.split(service.h1Gradient)[1]}
            </>
          ) : (
            service.h1
          )}
        </h1>
        <p class="text-xl md:text-2xl text-muted-foreground leading-relaxed mb-8 max-w-3xl">{service.heroLead}</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${contactBase}&topic=${service.ctaTopic}`} class="premium-btn">Обсудить пилот</a>
          <a
            href={`${contactBase}&topic=questionnaire`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-white/5 hover:bg-white/10 border border-white/10 transition-colors"
          >
            Получить опросный лист
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Какую задачу решает услуга</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {service.problem.map((item) => (
          <div class="glass-card p-6 flex items-start gap-3">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-muted-foreground leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scope -->
  <section class="py-12 bg-black/20 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Что входит в работы</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {service.scope.map((item) => (
          <li class="flex items-start gap-3 text-muted-foreground">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Out of scope -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl md:text-2xl font-heading font-bold text-white/90 mb-4">Что не входит в пилот</h2>
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-6 md:p-8">
        <ul class="space-y-3">
          {service.outOfScope.map((item) => (
            <li class="flex items-start gap-3 text-sm text-muted-foreground/80">
              <span class="text-white/30 shrink-0">—</span>
              <span class="leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-4">Архитектура внедрения</h2>
      <p class="text-lg text-muted-foreground mb-10 max-w-3xl leading-relaxed">{service.architecture.summary}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {service.architecture.components.map((comp) => (
          <div class="glass-card p-6">
            <div class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{comp.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{comp.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-sm text-muted-foreground/70 mt-8 leading-relaxed">{service.architecture.note}</p>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Стоимость пилота</h2>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <div class="glass-card p-8 md:p-10 border-l-4 border-l-accent lg:col-span-1">
          <div class="text-3xl md:text-4xl font-bold text-accent mb-2">{service.pricing.range}</div>
          <p class="text-white font-medium mb-6">Срок: {service.pricing.timeline}</p>
          <ul class="space-y-2 mb-6">
            {service.pricing.includes.map((item) => (
              <li class="flex items-start gap-2 text-muted-foreground text-sm">
                <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="text-xs text-muted-foreground/70 leading-relaxed">{service.pricing.disclaimer}</p>
        </div>
        <div class="lg:col-span-2">
          <h3 class="text-lg font-bold text-white mb-4">Калькулятор бюджета пилота</h3>
          <PilotCostCalculator
            idPrefix={`calc-${service.id}`}
            serviceId={service.id}
            defaults={service.pricing.calculatorDefaults}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {serviceFaq.length > 0 && (
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Частые вопросы</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {serviceFaq.map((item) => (
            <div class="glass-card p-6">
              <h3 class="text-lg font-bold text-white mb-3">{item.question}</h3>
              <p class="text-muted-foreground leading-relaxed text-sm">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related products -->
  {relatedProductCards.length > 0 && (
    <section class="pb-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Связанные продукты</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedProductCards.map((product) => (
            <a href={`/products/${product.id}/`} class="glass-card p-6 flex flex-col group hover:-translate-y-1 transition-transform h-full">
              <span class="text-xs font-bold text-accent mb-2">ПРОДУКТ {product.number}</span>
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">{product.name}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed mb-4">{product.shortDesc}</p>
              <span class="mt-auto text-sm text-primary font-medium flex items-center gap-1">
                Страница продукта
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related articles -->
  {service.relatedArticles?.length > 0 && (
    <section class="pb-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Связанные материалы</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {service.relatedArticles.map((article) => (
            <a href={`/blog/${article.slug}/`} class="glass-card p-6 flex flex-col group hover:-translate-y-1">
              <div class="text-white font-bold text-lg mb-2 group-hover:text-accent transition-colors">{article.title}</div>
              <p class="text-muted-foreground text-sm leading-relaxed flex-grow">{article.desc}</p>
              <div class="mt-4 text-sm text-primary font-medium">Читать статью →</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-3xl overflow-hidden border border-white/10">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-accent/20"></div>
        <div class="absolute inset-0 bg-background/40 backdrop-blur-xl"></div>
        <div class="relative p-10 md:p-16 text-center">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Запросите расчёт пилота</h2>
          <p class="text-lg text-muted-foreground mb-8 max-w-2xl mx-auto">
            Подготовим оценку сроков и бюджета по вашему контуру после опросного листа и opening discovery.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href={`${contactBase}&topic=${service.ctaTopic}`} class="premium-btn text-lg px-8 py-4">Обсудить пилот</a>
            <a
              href={`${contactBase}&topic=architecture-doc`}
              class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white bg-white/5 hover:bg-white/10 border border-white/10 transition-colors"
            >
              Запросить архитектурный документ
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
