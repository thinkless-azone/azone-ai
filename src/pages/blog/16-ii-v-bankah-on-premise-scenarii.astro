---
import Base from '../../layouts/Base.astro';

const title = 'ИИ в банках и финтехе: 6 рабочих сценариев on-premise';
const description = 'Почему публичные ИИ-сервисы в банке редко проходят согласование комплаенса и ИБ. Шесть сценариев on-premise LLM в закрытом контуре: контакт-центр, договоры, AML/KYC, скоринг, RAG, антифрод.';
const publishDate = '2026-05-18';
const readTime = '11 мин';
const tags = ['ИИ в банках', 'LLM для банков', 'on-premise ИИ', 'RAG', 'банковская тайна', 'закрытый контур', 'AML/KYC', 'антифрод', 'XAI'];
const coverImage = '/images/blog/16/cover.webp';
const slug = '16-ii-v-bankah-on-premise-scenarii';
const articleUrl = `https://azoneai.ru/blog/${slug}/`;

// Шесть сценариев — компактная карта вверху
const scenariosOverview = [
  { num: '1', icon: '🎧', title: 'Анализ клиентских обращений', gain: 'Классификация, тональность, резюме звонков, подсказки оператору' },
  { num: '2', icon: '📋', title: 'Compliance-проверка договоров', gain: 'Сравнение с типовой формой, поиск рискованных формулировок' },
  { num: '3', icon: '🔍', title: 'Поддержка операторов AML/KYC', gain: 'Сборка контекста, чек-листы, черновики — без автономных решений' },
  { num: '4', icon: '📊', title: 'Скоринг и объяснимость', gain: 'XAI: интерпретация факторов риска в человеческом виде' },
  { num: '5', icon: '📚', title: 'RAG по регламентам', gain: 'Ответы со ссылками на источники, разграничение доступа, версионность' },
  { num: '6', icon: '🛡️', title: 'Антифрод и аномалии', gain: 'LLM-обвязка над поведенческими моделями, приоритизация событий' },
];

// Почему облако проблематично
const cloudProblems = [
  { title: 'Банковская тайна', desc: 'Не только тайна вклада, но и обращения, договоры, выписки, заявки на кредит, данные о бенефициарах. Любой фрагмент в публичном промпте требует объяснений по защите данных, которые часто нечем подтвердить.' },
  { title: '152-ФЗ', desc: 'Большинство банковских процессов — обработка персональных данных. Подключение каждого нового внешнего сервиса требует переоценки политики, а для отдельных категорий — согласованной позиции комплаенса.' },
  { title: 'Внутренние ИБ-процедуры', desc: 'Подключение внешнего SaaS в крупном банке — отдельный проект на полгода: комитет, владелец риска, оценка поставщика, юридическая экспертиза. Иногда быстрее развернуть LLM в собственной стойке.' },
  { title: 'Теневой ИИ сотрудников', desc: 'Сотрудник, который в одиннадцать вечера копирует жалобу клиента в публичный чат, не злоумышленник — он просто хочет домой. Запретительные политики работают слабо без удобного легального инструмента.' },
];

// ИБ-обвязка
const securityLayers = [
  { title: 'Журналирование', desc: 'Кто, когда, по какому документу или кейсу обращался, какой получил ответ — фиксируется полностью.' },
  { title: 'Контроль доступа', desc: 'По ролям и источникам данных. Оператор не видит документов юридического или казначейского контура.' },
  { title: 'Маскирование', desc: 'Чувствительные поля в промптах и ответах обрабатываются отдельным модулем.' },
  { title: 'SIEM-интеграция', desc: 'События обращения к модели поступают в SIEM как полноценные ИБ-события.' },
  { title: 'DLP на исходящих ответах', desc: 'Чтобы не вынести наружу то, что в исходный набор попало случайно.' },
  { title: 'Сетевая изоляция', desc: 'Без прямого выхода в публичный интернет и доступа из общего корпоративного сегмента без отдельной авторизации.' },
  { title: 'Версионность модели', desc: 'Отзывная политика, процедура обновления, тестовая среда — стандартный набор управления.' },
  { title: 'Защита от prompt injection', desc: 'Регулярное тестирование, отдельной командой ИБ, не разработкой. Документы RAG — главный вектор атаки.' },
];

// KPI для пилота
const kpiList = [
  'Среднее время обработки клиентского обращения',
  'Доля обращений, классифицированных автоматически с приемлемой точностью',
  'Время поиска ответа по регламентам',
  'Число ошибок первичной договорной проверки',
  'Время подготовки юридического заключения',
  'Нагрузка на первую линию поддержки',
  'Время подготовки резюме разговора',
  'Число антифрод-событий, требующих ручной проверки',
  'Полнота журналирования действий пользователя',
  'Доля ответов ИИ со ссылками на источник',
];

// Дорожная карта внедрения
const roadmap = [
  { step: '1', title: 'Выбор сценария', desc: 'Один-два низкорисковых: RAG по регламентам, резюме обращений. Не больше — иначе пилот превратится в хаос.' },
  { step: '2', title: 'Владелец процесса', desc: 'Владелец продуктового результата и владелец риска. Без этого пилот превращается в технологический эксперимент.' },
  { step: '3', title: 'Набор документов', desc: 'Что в базе, что не в базе, как обновляется, что считать действующей версией.' },
  { step: '4', title: 'ИБ и комплаенс', desc: 'Согласовать в начале, а не на этапе опытной эксплуатации. Доступы к закрытым папкам СЭД — отдельная история.' },
  { step: '5', title: 'Пилот в контуре', desc: 'RAG, аудит, разграничение доступа, журналирование — базовый слой. Без него запускать смысла нет.' },
  { step: '6', title: 'Тестирование на боевом потоке', desc: 'Не на синтетических вопросах. Тестовые наборы всегда лучше боевых.' },
  { step: '7', title: 'KPI и стабилизация', desc: 'Замер метрик до и после. Стабилизация на боевом потоке.' },
  { step: '8', title: 'Масштабирование', desc: 'Только после того, как метрики стабилизировались. Подключение следующих сценариев.' },
];

// FAQ
const faqItems = [
  {
    q: 'Можно ли использовать публичные облачные ИИ-сервисы для работы с банковской информацией?',
    a: 'Для отдельных публичных задач — маркетинг, перевод нечувствительных материалов — это возможно после правовой и ИБ-оценки. Для процессов, в которые попадают банковская тайна, персональные данные клиентов, фрагменты договоров и обращений, публичное облако обычно не проходит согласование. Точную оценку для конкретного процесса должны давать комплаенс и ИБ банка.'
  },
  {
    q: 'Чем on-premise LLM отличается от обычной локальной программы?',
    a: 'On-premise LLM — это не только модель, но и обвязка: сервер инференса, векторная база, RAG, журналирование, разграничение доступа, интеграции с корпоративными системами. Развёртывание идёт в инфраструктуре банка, данные не покидают периметр, аудит ведётся внутри.'
  },
  {
    q: 'Принимает ли ИИ решение в AML/KYC и скоринге?',
    a: 'В корректно спроектированном банковском контуре — нет. ИИ помогает оператору быстрее собрать контекст, готовит черновики, классифицирует типовые ситуации. Юридически значимые решения принимаются человеком в рамках регламентов банка.'
  },
  {
    q: 'Что такое RAG и почему он безопаснее для банка, чем обычный чат-бот?',
    a: 'RAG (Retrieval-Augmented Generation) строит ответ на основе утверждённой базы документов и даёт ссылки на источники. Модель не «придумывает» ответ из общих знаний, а опирается на конкретные регламенты с фиксированной версией. Это даёт контроль, проверяемость и аудит.'
  },
  {
    q: 'С каких сценариев банку реалистично начать пилот?',
    a: 'Самые безопасные точки входа — RAG-помощник по внутренним регламентам и анализ клиентских обращений в контакт-центре. Они дают измеримый эффект, не затрагивают юридически значимых решений и позволяют отстроить ИБ-обвязку до перехода к чувствительным сценариям.'
  },
  {
    q: 'Что обязательно нужно учесть на стороне ИБ?',
    a: 'Журналирование запросов и ответов, разграничение доступа по ролям и источникам, маскирование чувствительных полей, интеграция с SIEM и DLP, изоляция контура, контроль prompt injection, версионность модели, политика использования ИИ сотрудниками. Это проектируется с первого дня, а не достраивается потом.'
  },
];

// Schema.org JSON-LD
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "ИИ в банках и финтехе: 6 рабочих сценариев on-premise без отправки данных в облако",
  "description": description,
  "image": `https://azoneai.ru${coverImage}`,
  "datePublished": publishDate,
  "dateModified": publishDate,
  "author": {
    "@type": "Organization",
    "name": "AZONE-AI",
    "url": "https://azoneai.ru/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AZONE-AI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://azoneai.ru/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  },
  "keywords": tags.join(', '),
  "articleSection": "Отраслевые сценарии",
  "inLanguage": "ru-RU"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://azoneai.ru/" },
    { "@type": "ListItem", "position": 2, "name": "Блог", "item": "https://azoneai.ru/blog/" },
    { "@type": "ListItem", "position": 3, "name": "ИИ в банках и финтехе: 6 сценариев on-premise", "item": articleUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Base title={title} description={description} articleDate={publishDate} image={coverImage}>

  <Fragment slot="head">
    <link rel="canonical" href={articleUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://azoneai.ru${coverImage}`} />
    <meta property="og:url" content={articleUrl} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="article:published_time" content={publishDate} />
    <meta property="article:section" content="Отраслевые сценарии" />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://azoneai.ru${coverImage}`} />
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <main class="flex-grow">

  <!-- Hero -->
  <section class="relative pt-28 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div>
        <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-accent transition-colors mb-8">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Назад к блогу
        </a>

        <div class="mb-6 flex items-center gap-3 flex-wrap">
          {tags.map((tag) => (
            <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-xs font-medium text-accent border border-white/10">{tag}</span>
          ))}
        </div>

        <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6 leading-tight">
          ИИ в&nbsp;банках и&nbsp;финтехе: 6&nbsp;рабочих сценариев on-premise без&nbsp;отправки данных в&nbsp;облако
        </h1>

        <p class="text-xl text-muted-foreground mb-8 leading-relaxed">
          Почему публичные ИИ-сервисы в&nbsp;банке редко проходят согласование комплаенса и&nbsp;ИБ&nbsp;— и&nbsp;как выглядит реалистичный путь через закрытый контур
        </p>

        <div class="flex items-center gap-6 text-sm text-muted-foreground pb-6 border-b border-white/10">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            15 мая 2026
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            {readTime}
          </span>
        </div>

        <a href="/industries/banki/" class="inline-flex items-center gap-2 mt-6 mb-2 px-4 py-2 rounded-xl bg-primary/10 border border-primary/30 text-sm font-medium text-primary hover:bg-primary/20 hover:text-accent transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Отрасль: Банки и финтех — сценарии внедрения on-premise
        </a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-invert prose-lg max-w-none space-y-12 text-muted-foreground">

        <!-- Cover -->
        <div class="mb-4">
          <img src="/images/blog/16/cover.webp" alt="Закрытый контур банка с локальной LLM: данные не покидают периметр, ИИ-модуль связан с СЭД, CRM, SIEM, IAM и DLP" class="w-full rounded-2xl object-cover" loading="eager">
        </div>

        <!-- Intro -->
        <div class="space-y-4">
          <p>Банковский ИИ-проект почти никогда не&nbsp;начинается с&nbsp;выбора модели. Он&nbsp;начинается с&nbsp;вопроса, который задаёт CISO или директор по&nbsp;комплаенсу: где будут жить данные, кто к&nbsp;ним получит доступ и&nbsp;как это потом доказать аудитору. Поэтому популярная схема «возьмём публичный сервис и&nbsp;подключим сотрудников через корпоративный логин» обычно разбивается о&nbsp;первую&nbsp;же серьёзную проверку контура.</p>

          <p>Это не&nbsp;значит, что банк остаётся без искусственного интеллекта. Это значит, что путь к&nbsp;нему другой&nbsp;— и&nbsp;он&nbsp;короче, чем кажется. Ниже&nbsp;— шесть сценариев, которые в&nbsp;российских банках и&nbsp;финтех-компаниях работают уже несколько лет. Не&nbsp;в&nbsp;облаке. Без громких обещаний. И&nbsp;без перекладывания ответственности на&nbsp;регулятора.</p>
        </div>

        <!-- Карта сценариев -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Шесть сценариев в&nbsp;одной картинке</h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {scenariosOverview.map((s) => (
              <div class="p-5 rounded-xl bg-white/[0.03] border border-white/10 flex items-start gap-3">
                <div class="text-2xl shrink-0">{s.icon}</div>
                <div>
                  <div class="text-accent font-bold mb-1 text-sm">Сценарий {s.num}</div>
                  <div class="text-white font-semibold mb-2">{s.title}</div>
                  <p class="text-sm leading-relaxed">{s.gain}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Почему облако проблематично -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Почему облачные ИИ-сервисы в&nbsp;банке проходят согласование с&nbsp;трудом</h2>
          </div>

          <div class="space-y-4">
            <p>Банковская тайна&nbsp;— это не&nbsp;только тайна вклада и&nbsp;операции. Это весь массив сведений, которые банк получает в&nbsp;связи с&nbsp;обслуживанием клиента: переписка, обращения, заявления, скан-копии договоров, выписки, фрагменты заявок на&nbsp;кредит, данные о&nbsp;бенефициарах. Если такой фрагмент попадает в&nbsp;публичный сервис&nbsp;— даже временно, даже в&nbsp;форме промпта&nbsp;— у&nbsp;банка появляется обязанность объяснить, как именно были соблюдены требования по&nbsp;защите этих данных. И&nbsp;часто оказывается, что объяснить нечего: маршрут данных недокументирован, провайдер инференса находится за&nbsp;периметром, журналов запросов нет, политика хранения непрозрачна.</p>

            <div class="my-6">
              <img src="/images/blog/16/cloud-vs-onprem.webp" alt="Сравнение облачной и on-premise архитектуры ИИ для банка: данные уходят за периметр или остаются внутри" class="w-full rounded-2xl object-cover" loading="lazy">
              <p class="text-sm text-muted-foreground/60 text-center mt-3 italic">Облачная схема и&nbsp;on-premise-контур&nbsp;— разный режим обработки данных и&nbsp;разные последствия для аудита</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
              {cloudProblems.map((item) => (
                <div class="p-5 rounded-xl bg-white/[0.03] border border-white/10 border-l-4 border-l-red-500/40">
                  <div class="text-white font-bold mb-2">{item.title}</div>
                  <p class="text-sm leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>

            <p class="mt-6">Это не&nbsp;значит, что любой облачный ИИ&nbsp;для банка под полным запретом. Маркетинговые тексты, переводы публичных материалов&nbsp;— после правовой и&nbsp;ИБ-оценки могут быть допустимы. Но&nbsp;для процессов, в&nbsp;которые попадают клиентские данные, путь обычно один: внутрь периметра.</p>
          </div>
        </div>

        <!-- Что даёт on-premise -->
