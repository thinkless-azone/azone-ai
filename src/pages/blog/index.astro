---
<Base
  title="Блог об ИИ для бизнеса: внедрение, безопасность, кейсы"
  description="Экспертный блог AZONE-AI: внедрение LLM on-premise, безопасность данных, ИИ для КИИ, кейсы и практические руководства для бизнеса и госсектора."
>

  <section class="pt-24 py-20 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-white mb-6 animate-fade-up">База <span class="text-gradient">знаний</span></h1>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto animate-fade-up animate-delay-100">Экспертные статьи о внедрении искусственного интеллекта, безопасности данных и On-Premise решениях.</p>
      <div class="mt-8 max-w-2xl mx-auto">
        <div class="glass-card p-3 md:p-4 text-left">
          <label for="blogFilterInput" class="block text-xs text-muted-foreground mb-2">Быстрый поиск по статьям</label>
          <input
            id="blogFilterInput"
            type="search"
            placeholder="Например: LLM, КИИ, on-premise, безопасность..."
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all"
          />
          <p id="blogFilterCount" class="mt-2 text-xs text-muted-foreground">Найдено: {articles.length}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="blogGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article) => (
          <a
            href={article.href}
            class="glass-card flex flex-col group cursor-pointer"
            data-article
            data-search={`${article.title} ${article.desc} ${article.category}`.toLowerCase()}
          >
            <div class="p-6 flex-grow flex flex-col">
              <div class="mb-4">
                <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-xs font-medium text-accent border border-white/10">{article.category}</span>
              </div>
              <h2 class="text-xl font-bold text-white mb-3 group-hover:text-primary transition-colors">{article.title}</h2>
              <p class="text-muted-foreground text-sm leading-relaxed mb-6 flex-grow">{article.desc}</p>
              <div class="pt-6 border-t border-white/10 flex items-center justify-between text-xs text-muted-foreground mt-auto">
                <div class="flex items-center gap-4">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {article.date}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {article.readTime}
                  </span>
                </div>
                <svg class="w-4 h-4 text-primary group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div id="blogNoResults" class="hidden mt-8 text-center text-sm text-muted-foreground">
        Ничего не найдено. Попробуйте другой запрос или откройте страницу <a href="/search/" class="text-accent hover:underline">поиска по сайту</a>.
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="relative rounded-3xl overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-accent/20"></div>
        <div class="absolute inset-0 bg-background/40 backdrop-blur-xl"></div>
        <div class="absolute inset-0 border border-white/10 rounded-3xl"></div>
        <div class="relative p-10 md:p-16 text-center">
          <h2 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6">Начните с <span class="text-gradient">пилотного проекта</span></h2>
          <p class="text-lg text-muted-foreground mb-10 max-w-2xl mx-auto">За 4–8 недель мы развернём решение на вашей инфраструктуре.</p>
          <a href="/contact/?product=other" class="premium-btn text-lg px-8 py-4">Обсудить пилот</a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const filterInput = document.getElementById('blogFilterInput');
    const articleCards = Array.from(document.querySelectorAll('[data-article]'));
    const resultCount = document.getElementById('blogFilterCount');
    const noResults = document.getElementById('blogNoResults');
    let trackedFilterUsage = false;

    const applyFilter = () => {
      if (!filterInput) return;
      const query = filterInput.value.trim().toLowerCase();
      let visible = 0;
      articleCards.forEach((card) => {
        const haystack = card.getAttribute('data-search') || '';
        const matched = !query || haystack.includes(query);
        card.classList.toggle('hidden', !matched);
        if (matched) visible += 1;
      });
      if (resultCount) resultCount.textContent = `Найдено: ${visible}`;
      if (noResults) noResults.classList.toggle('hidden', visible !== 0);

      if (!trackedFilterUsage && query.length >= 2) {
        trackedFilterUsage = true;
        if (typeof ym !== 'undefined') ym(108466305, 'reachGoal', 'blog_filter_use');
      }
    };

    filterInput?.addEventListener('input', applyFilter);
  </script>
</Base>
