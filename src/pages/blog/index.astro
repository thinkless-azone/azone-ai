---
import Base from '../../layouts/Base.astro';

const articles = [
  {
	id:12,
	title:"Открытые данные и ИИ: что изменилось в конкурентной разведке",
	desc:"Вакансии, тендеры, пресс-релизы, технологический стек — что машина уже читает хорошо, а что пока читать за ней. Практический разбор OSINT с ИИ и рабочего контура с верификацией.",
	date: "23 Апреля, 2026",
	readTime: '10 мин',
	category: 'Безопасность',
	href:"/blog/12-ii-dlya-osint/" },
  {
	id:11,
	title:"Зашумить, чтобы защитить: можно ли маскировать персональные данные в запросах к нейросетям",
	desc:"Prompt perturbation, дифференциальная приватность и on-premise LLM — где проходит граница между реальной защитой данных и иллюзией безопасности.",
	date: "13 Апреля, 2026", 
	readTime: '10 мин',
	category: 'Безопасность',
	href:"/blog/11-prompt-perturbation-privacy-llm/" },
  { id:10, 
	title:"Сравнение отечественных LLM: YandexGPT, GigaChat и альтернативы", 
	desc:"Объективное сравнение российских языковых моделей для корпоративного использования. Критерии выбора, цены, on-premise, RAG — практическое руководство.", 
	date:"07 Апреля, 2026", 
	readTime:"10 мин", 
	category:"Технологии", 
	href:"/blog/10-sravnenie-llm/" },
  { id:9, 
	title:"ИИ в информационной безопасности: 7 практических сценариев — SIEM, DLP, SOAR", 
	desc:"Как нейросети усиливают SIEM, DLP и SOAR. 7 кейсов автоматизации ИБ: от приоритизации алертов до LLM-ассистентов аналитиков SOC. Ограничения, риски и принципы внедрения.", 
	date:"31 Марта, 2026", 
	readTime:"12 мин", 
	category:"Регулирование", 
	href:"/blog/09-ii-v-informacionnoy-bezopasnosti-7-scenariev/" },
  { id:8, 
	title:"Реестр доверенных ИИ-моделей в России: что уже известно и как подготовиться", 
	desc:"Законопроект Минцифры, приказ ФСТЭК № 117, перечень доверенного ПО — разбираем регулирование ИИ и даём чек-лист для бизнеса.", 
	date:"17 Марта, 2026", 
	readTime:"12 мин", 
	category:"Регулирование", 
	href:"/blog/08-reestr-doverennyh-ii-modelej-rossiya-2026/" },
  { id:7, 
	title:"Как развернуть LLM в закрытом контуре: пошаговое руководство", 
	desc:"Llama, Mistral или Qwen? Сравнение моделей, квантизация, vLLM vs TGI, требования к железу — полный гайд по развёртыванию LLM on-premise для ИБ-специалистов.", 
	date:"10 Марта, 2026", 
	readTime:"10 мин", 
	category:"Технологии", 
	href:"/blog/07-llm-closed-circuit-guide/" },
  { id:6, 
	title:"152-ФЗ и нейросети: как внедрить ИИ и не нарушить закон", 
	desc:"Юридические аспекты обработки персональных данных с помощью алгоритмов искусственного интеллекта. Практика обезличивания и защиты.", 
	date:"3 Марта, 2025", 
	readTime:"10 мин", 
	category:"Compliance", 
	href:"/blog/06-pdn-ai/" },
  { id:5, 
	title:"Предиктивная аналитика: предотвращение аварий до их возникновения", 
	desc:"Как машинное обучение анализирует данные SCADA-систем и помогает перейти от планово-предупредительного ремонта к обслуживанию по состоянию.", 
	date:"25 Февраля, 2026", 
	readTime:"9 мин", 
	category:"Технологии", 
	href:"/blog/05-predict-maintain/" },
  { id:4, 
	title:"AI в строительстве: видеоаналитика для контроля безопасности", 
	desc:"Использование компьютерного зрения для автоматического выявления нарушений техники безопасности и контроля использования СИЗ на стройплощадках.", 
	date:"17 Февраля, 2026", 
	readTime:"7 мин", 
	category:"Продукты", 
	href:"/blog/04-construction-eye/" },
  { id:3, 
	title:"Как ИИ сокращает время поиска документов с часов до минут", 
	desc:"Разбор кейса внедрения нейросетевого архива в крупном промышленном холдинге. Семантический поиск по архиву из 5 миллионов скан-копий.", 
	date:"10 Февраля, 2026", 
	readTime:"6 мин", 
	category:"Кейсы", 
	href:"/blog/03-azonedoc-case/" },
  { id:2, 
	title:"On-premise LLM: как развернуть языковую модель внутри периметра", 
	desc:"Технический гайд по выбору open-source моделей, требованиям к железу (GPU) и процессу тонкой настройки (fine-tuning) на корпоративных данных.", 
	date:"3 Февраля, 2026", 
	readTime:"12 мин", 
	category:"Технологии", 
	href:"/blog/02-on-premise-llm/" },
  { id:1, 
	title:"Почему облачный ИИ не подходит для КИИ и объектов с гостайной", 
	desc:"Анализируем риски утечки данных через API публичных моделей и рассказываем о требованиях регуляторов к внедрению ИИ на объектах критической инфраструктуры.", 
	date:"27 Января, 2026", 
	readTime:"8 мин", 
	category:"Безопасность", 
	href:"/blog/01-cloud-ai-kii/" },
