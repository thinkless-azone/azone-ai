---
import Base from '../../layouts/Base.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';

const statusTable = [
  { aspect: "Требования к защите ИИ в ГИС", status: "active", statusText: "Действует с 01.03.2026", doc: "Приказ ФСТЭК № 117", action: "Провести аудит ИИ-компонентов в ГИС, определить шаблоны запросов/ответов, критерии достоверности" },
  { aspect: "Запрет иностранных СЗИ на КИИ", status: "active", statusText: "Действует с 01.01.2026", doc: "Указ Президента № 250", action: "Завершить замену иностранных СЗИ, включая компоненты в ИИ-контуре" },
  { aspect: "Перечень доверенного российского ПО", status: "active", statusText: "Действует с 01.03.2026", doc: "ФЗ-325, ПП РФ № 1931", action: "Убедиться, что используемое ПО включено в перечень доверенного" },
  { aspect: "Переход на доверенные ПАК для КИИ", status: "active", statusText: "Действует", doc: "187-ФЗ (ред. 2025)", action: "Планировать замену ПАК, закладывать бюджеты" },
  { aspect: "Реестр доверенных моделей ИИ", status: "draft", statusText: "Проект", doc: "Законопроект Минцифры (март 2026)", action: "Проектировать решения с учётом будущих требований" },
  { aspect: "Стандарт безопасной разработки ИИ", status: "draft", statusText: "Проект, не опубликован", doc: "Анонс ФСТЭК (сентябрь 2025)", action: "Ориентироваться на ГОСТ Р 56939-2024" },
  { aspect: "Раскрытие обучающих данных", status: "discussion", statusText: "Обсуждение", doc: "Отраслевая инициатива", action: "Документировать наборы данных и их происхождение" },
  { aspect: "Критерии отечественности ИИ", status: "discussion", statusText: "Обсуждение", doc: "Аппарат вице-премьера", action: "Анализировать зависимости от зарубежных компонентов" },
];

const steps = [
  { num: "1", title: "Провести инвентаризацию ИИ-компонентов", text: "Где в вашей инфраструктуре используются модели ИИ? Какие из них облачные, какие on-premise? Какие данные обрабатывают? Где физически расположены вычислительные ресурсы?" },
  { num: "2", title: "Оценить зависимость от зарубежных компонентов", text: "Модели, фреймворки, библиотеки, облачные API, средства защиты — проверить весь стек на наличие иностранных элементов." },
  { num: "3", title: "Спланировать переход на on-premise", text: "Облачные зарубежные сервисы для данных ГИС или КИИ уже запрещены. Локальное развёртывание — не опция, а требование." },
  { num: "4", title: "Выстроить документирование", text: "Фиксировать происхождение обучающих данных, версии моделей, результаты тестирования, конфигурации безопасности." },
  { num: "5", title: "Внедрить контроль доступа и журналирование", text: "Кто имеет доступ к модели? Какие запросы обрабатываются? Как логируются ответы? Эти меры уже подразумеваются приказом ФСТЭК № 117." },
  { num: "6", title: "Провести оценку угроз, специфичных для ИИ", text: "Adversarial-атаки, отравление данных, prompt injection — классические модели угроз их не покрывают." },
  { num: "7", title: "Привлечь профильного интегратора", text: "Развёртывание ИИ в закрытом контуре с соблюдением требований ФСТЭК и ФСБ — задача, требующая лицензий и экспертизы." },
  { num: "8", title: "Заложить бюджет на приведение в соответствие", text: "Отечественные ПАК, on-premise, аттестация, тестирование безопасности — закладывайте в бюджетный цикл 2026–2027." },
];

const faq = [
  { q: "Реестр доверенных моделей ИИ уже существует?", a: "Нет. По состоянию на апрель 2026 года реестр не создан. Его создание предусмотрено проектом федерального закона, опубликованным Минцифры 18 марта 2026 года. Предполагаемая дата вступления в силу — 1 сентября 2027 года. При этом уже действует перечень доверенного российского ПО (ПП РФ № 1931 от 28.11.2025)." },
  { q: "Можно ли сейчас использовать зарубежные ИИ-модели в госсекторе?", a: "Прямого запрета именно на зарубежные ИИ-модели пока нет. Однако приказ ФСТЭК № 117 запрещает облачные ИИ-сервисы для данных ограниченного доступа. Указ № 250 запрещает иностранные СЗИ на КИИ. Пространство для зарубежных ИИ в чувствительных средах уже сильно ограничено." },
  { q: "Нужна ли сертификация ФСТЭК/ФСБ для ИИ-моделей прямо сейчас?", a: "Отдельная процедура сертификации ИИ-моделей не установлена. Законопроект говорит о «подтверждении соответствия», но порядок не утверждён. Если ИИ-система работает как часть ГИС или КИИ, на неё распространяются существующие требования ФСТЭК." },
  { q: "Кого затронет регулирование в первую очередь?", a: "ГИС и значимые объекты КИИ госорганов. В аппарате вице-премьера Григоренко подчеркнули, что коммерческий сектор напрямую не затронут. Но компании, работающие с госзаказчиками, будут вынуждены соответствовать де-факто." },
  { q: "Что делать, если мы уже внедряем ИИ?", a: "Проектировать с запасом: локализация данных, on-premise, документирование, контроль доступа, журналирование. Привлечение интегратора с лицензиями ФСТЭК и ФСБ на этапе проектирования — самый надёжный способ не переделывать потом." },
];

const risks = [
  { title: "Юридические", text: "Невозможность использовать ИИ-решение в госконтрактах или на объектах КИИ. С 2025 года ФСТЭК провела 700+ проверок КИИ и зафиксировала свыше 1100 нарушений.", color: "red" },
  { title: "Инфраструктурные", text: "Миграция с облачных ИИ-сервисов на on-premise занимает месяцы. Начинать в момент вступления закона — значит не успеть.", color: "orange" },
  { title: "ИБ-риски", text: "ИИ-система без защиты — вектор атаки: утечки через промпты, манипуляции обучающими данными, несанкционированный доступ к модели.", color: "red" },
  { title: "Закупочные", text: "ПО не из перечня доверенного уже приравнивается к иностранному. Модели вне реестра рискуют выпасть из легального применения.", color: "yellow" },
  { title: "Репутационные", text: "Для компаний с госзаказчиками неготовность к регуляторным требованиям — сигнал ненадёжности.", color: "yellow" },
];
const relatedArticles = [
  { title: "152-ФЗ и нейросети: как внедрить ИИ и не нарушить закон", href: "/blog/06-pdn-ai", category: "Compliance", readTime: "10 мин" },
  { title: "Почему облачный ИИ не подходит для КИИ и объектов с гостайной", href: "/blog/01-cloud-ai-kii", category: "Безопасность", readTime: "8 мин" },
  { title: "ИИ в информационной безопасности: 7 практических сценариев", href: "/blog/09-ii-v-informacionnoy-bezopasnosti-7-scenariev", category: "Регулирование", readTime: "12 мин" },
];
---
<Base title="Реестр доверенных ИИ-моделей в России 2026: что действует, что в проекте и как подготовиться бизнесу" description="Реестр доверенных ИИ-моделей, требования ФСТЭК и ФСБ, законопроект Минцифры 2026 — разбираем регулирование ИИ в России и даём практический чек-лист для бизнеса." articleDate="2026-04-03">

      <section class="relative pt-28 pb-16 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent pointer-events-none"></div>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div>
            <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-accent transition-colors mb-8">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Назад к блогу
            </a>
            <div class="mb-6 flex items-center gap-3">
              <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-xs font-medium text-accent border border-white/10">Регулирование</span>
              <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-xs font-medium text-accent border border-white/10">Безопасность</span>
            </div>
            <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6 leading-tight">Реестр доверенных ИИ&#8209;моделей в&nbsp;России: что&nbsp;уже известно, что&nbsp;действует и&nbsp;как подготовиться бизнесу</h1>
            <p class="text-xl text-muted-foreground mb-8 leading-relaxed">Законопроект Минцифры, приказ ФСТЭК&nbsp;№&nbsp;117, перечень доверенного ПО&nbsp;— разбираем, какие нормы уже работают, какие на&nbsp;подходе, и&nbsp;что делать бизнесу прямо сейчас.</p>
            <div class="flex items-center gap-6 text-sm text-muted-foreground pb-8 border-b border-white/10">
              <span class="flex items-center gap-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> 3 апреля 2026</span>
              <span class="flex items-center gap-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 12 мин чтения</span>
            </div>
          </div>
        </div>
      </section>

      <section class="pb-24">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="space-y-12 text-muted-foreground leading-relaxed text-[17px]">

            <div>
              <p>18&nbsp;марта 2026&nbsp;года Минцифры опубликовало проект федерального закона «Об&nbsp;основах государственного регулирования применения технологий искусственного интеллекта». Среди ключевых нововведений&nbsp;— создание <strong class="text-white">реестра доверенных моделей ИИ</strong>. Если закон примут в&nbsp;текущей редакции, с&nbsp;1&nbsp;сентября 2027&nbsp;года государственные информационные системы и&nbsp;объекты КИИ смогут работать только с&nbsp;моделями из&nbsp;этого реестра.</p>
              <p class="mt-4">Одновременно уже с&nbsp;1&nbsp;марта 2026&nbsp;года действуют обновлённые требования ФСТЭК к&nbsp;защите информации в&nbsp;ГИС (приказ&nbsp;№&nbsp;117), впервые затрагивающие системы на&nbsp;основе ИИ. А&nbsp;с&nbsp;1&nbsp;января 2026&nbsp;года вступил в&nbsp;полную силу запрет на&nbsp;иностранные СЗИ на&nbsp;объектах КИИ.</p>
              <p class="mt-4">Картина складывается из&nbsp;нескольких слоёв: одни нормы уже работают, другие — на&nbsp;стадии законопроекта, третьи&nbsp;— в&nbsp;виде обсуждаемых инициатив. В&nbsp;этом материале мы&nbsp;разделяем эти слои и&nbsp;разбираемся, что конкретно стоит делать бизнесу уже сейчас.</p>
            </div>

            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Почему тема доверенного ИИ стала критически важной</h2>
              </div>
              <p>Ещё в&nbsp;2024&nbsp;году Президент&nbsp;РФ утвердил обновлённую Национальную стратегию развития ИИ на&nbsp;период до&nbsp;2030&nbsp;года (Указ&nbsp;№&nbsp;124 от&nbsp;15.02.2024). Уже тогда появился раздел о&nbsp;внедрении «доверенных технологий ИИ» и&nbsp;задача формирования на&nbsp;платформе «ГосТех» реестра апробированных решений.</p>
              <p class="mt-4">К&nbsp;весне 2026&nbsp;года формируется полноценная законодательная рамка: ИИ&nbsp;стремительно входит в&nbsp;критически важные процессы, а&nbsp;методическая база для его безопасного применения существенно отстаёт от&nbsp;практики.</p>
              <img src="/images/blog/reestr-ii-timeline.webp" alt="Хронология регулирования ИИ в России: от Указа № 490 (2019) до законопроекта о реестре доверенных моделей (2027)" class="w-full rounded-2xl object-cover mt-6" />
              <p class="text-sm text-muted-foreground/60 text-center mt-3 italic">Хронология регуляторных событий: зелёный&nbsp;— действует, жёлтый&nbsp;— проект, серый&nbsp;— обсуждение</p>
            </div>

            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Что понимается под «доверенным ИИ»</h2>
              </div>
              <p>Законопроект Минцифры вводит три ключевых понятия.</p>
              <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
                {[
                  { term: "Суверенная модель", desc: "Все стадии разработки, обучения и эксплуатации — на территории России, гражданами РФ и российскими юрлицами, на отечественных данных." },
                  { term: "Национальная модель", desc: "Аналогична суверенной, с акцентом на полный цикл «отечественности» от данных до инфраструктуры." },
                  { term: "Доверенная модель", desc: "Прошла проверку безопасности (ФСТЭК, ФСБ) и качества. Обработка данных — только на территории РФ. Включена в специальный реестр." },
                ].map((item) => (
                  <div class="p-5 rounded-xl bg-white/[0.03] border border-white/10">
                    <div class="text-lg font-bold text-accent mb-2">{item.term}</div>
                    <p class="text-sm leading-relaxed">{item.desc}</p>
                  </div>
                ))}
              </div>
              <p class="mt-6">Именно статус «доверенной» модели станет пропуском в&nbsp;ГИС и&nbsp;на&nbsp;значимые объекты КИИ. Проект закона прямо говорит о&nbsp;допуске только моделей из&nbsp;реестра.</p>
              <div class="mt-6 p-5 rounded-xl bg-yellow-500/5 border border-yellow-500/20">
                <p class="text-sm"><span class="text-white font-semibold">Важно:</span> пока это именно проект. Документ на&nbsp;стадии общественного обсуждения и&nbsp;межведомственного согласования. Финальная редакция может существенно измениться. Но&nbsp;направление задано, и&nbsp;игнорировать его рискованно.</p>
              </div>
            </div>

            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Что уже действует сейчас</h2>
              </div>
              <p>Хотя реестр доверенных ИИ-моделей ещё не&nbsp;создан, регуляторная среда уже существует.</p>
              <div class="mt-6 space-y-4">
                {[
                  { title: "Приказ ФСТЭК № 117 (действует с 01.03.2026)", text: "Заменил приказ № 17. Впервые устанавливает требования к защите ИИ в ГИС: шаблоны запросов/ответов, критерии достоверности, запрет облачных ИИ-сервисов для данных ограниченного доступа." },
                  { title: "Указ Президента № 250 — запрет иностранных СЗИ на КИИ", text: "С 1 января 2026 года. Если в вашем ИИ-контуре зарубежные компоненты защиты — это уже нарушение." },
                  { title: "187-ФЗ о безопасности КИИ (ред. 2025)", text: "Закрепляет переход на доверенные ПАК и ориентацию на отечественное ПО для объектов КИИ." },
                  { title: "325-ФЗ + ПП РФ № 1931 от 28.11.2025", text: "Перечень доверенного ПО. ПО не из перечня приравнивается к иностранному при закупках. Прецедент для будущего реестра ИИ-моделей." },
                  { title: "ГОСТ Р 56939-2024", text: "Стандарт безопасной разработки ПО, на который ссылается приказ ФСТЭК № 117. Базовый ориентир до появления специализированного стандарта для ИИ." },
                ].map((item) => (
                  <div class="flex items-start gap-4 p-6 rounded-2xl bg-white/[0.03] border border-white/10">
                    <svg class="w-6 h-6 text-green-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <div>
                      <h3 class="text-white font-bold mb-2">{item.title}</h3>
                      <p class="text-sm leading-relaxed">{item.text}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-yellow-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-yellow-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Что на стадии проекта или обсуждения</h2>
              </div>
              <div class="space-y-4">
                {[
                  { title: "Законопроект Минцифры об ИИ", badge: "Проект", bc: "yellow", text: "Опубликован 18.03.2026. Вступление в силу — 1 сентября 2027. Реестр доверенных моделей, понятия суверенной и национальной модели, ответственность участников, маркировка контента." },
                  { title: "Стандарт ФСТЭК по безопасной разработке ИИ", badge: "Проект", bc: "yellow", text: "Анонсирован в сентябре 2025: «галлюцинации», отравление выборок, утечки через промпты, adversarial-атаки. По состоянию на апрель 2026 — не опубликован." },
                  { title: "Раскрытие обучающих данных", badge: "Обсуждение", bc: "gray", text: "Идея обязать раскрывать сведения о наборах данных. В текущей версии законопроекта требования нет." },
                  { title: "Критерии «отечественности» нейросетей", badge: "Обсуждение", bc: "gray", text: "Правительство прорабатывает критерии. Вопрос не тривиальный из-за зависимости от зарубежных архитектур и фреймворков." },
                ].map((item) => (
                  <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/10">
                    <div class="flex items-center gap-3 mb-2">
