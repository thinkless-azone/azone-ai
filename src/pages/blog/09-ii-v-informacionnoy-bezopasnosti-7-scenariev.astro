        </div>

        <!-- 7 сценариев: обзор -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">7&nbsp;сценариев применения ИИ в&nbsp;ИБ</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {scenarios.map((s) => (
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/10 flex items-start gap-3">
                <span class="text-xl shrink-0">{s.icon}</span>
                <div>
                  <div class="text-white font-bold text-sm">{s.title}</div>
                  <div class="text-xs text-muted-foreground/70 mt-1">{s.gain}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {scenarioDetails.map((scenario) => (
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-yellow-500/20 flex items-center justify-center shrink-0"><span class="text-yellow-400 font-bold text-sm">{scenario.num}</span></div>
              <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">{scenario.title}</h2>
            </div>
            <h3 class="text-white font-semibold mt-4 mb-2">Где используется</h3>
            <p>{scenario.where}</p>
            <h3 class="text-white font-semibold mt-4 mb-2">Какую задачу решает</h3>
            <p>{scenario.problem}</p>
            <h3 class="text-white font-semibold mt-4 mb-2">Как работает на практике</h3>
            <div class="space-y-4">
              {scenario.practice.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
            {scenario.image && (
              <div>
                <img src={scenario.image} alt={scenario.imageAlt} class="w-full rounded-2xl object-cover mt-6 mb-0" loading="lazy" />
                <p class="text-sm text-muted-foreground/60 text-center mt-3 mb-6 italic">{scenario.imageCaption}</p>
              </div>
            )}
            <div class="mt-6 p-5 rounded-xl bg-green-500/5 border border-green-500/20">
              <p class="text-sm"><span class="text-green-400 font-semibold">В чём выигрыш. </span>{scenario.benefit}</p>
            </div>
            <div class="mt-3 p-5 rounded-xl bg-yellow-500/5 border border-yellow-500/20">
              <p class="text-sm"><span class="text-white font-semibold">Ограничения.</span> {scenario.limitations}</p>
            </div>
            <div class="mt-3 p-5 rounded-xl bg-blue-500/5 border border-blue-500/20">
              <p class="text-sm"><span class="text-white font-semibold">Где нужен контроль человека.</span> {scenario.humanControl}</p>
            </div>
          </div>
        ))}

        <!-- Ограничения -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Где нейросети полезны, а&nbsp;где их&nbsp;переоценивают</h2>
