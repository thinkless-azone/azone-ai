---
import Base from '../../layouts/Base.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
const relatedProducts = [
  { name: 'AzoneDoc', href: '/products/azonedoc/', tag: 'Документооборот', desc: 'Готовое решение для корпоративного архива с on-premise LLM. Быстрый пилот, интеграция с 1С, SAP, ELMA.' },
  { name: 'ContractGuard', href: '/products/contractguard/', tag: 'Юридическая аналитика', desc: 'LLM в закрытом контуре для compliance-анализа договоров. On-premise, дообучение на данных заказчика.' },
];

const modelTable = [
  { criterion: "Качество ответов",  llama: "★★★★★", mistral: "★★★★",  qwen: "★★★★★", note: "Llama и Qwen лидируют на 70B+" },
  { criterion: "Код и данные",      llama: "★★★★",  mistral: "★★★★",  qwen: "★★★★★", note: "Qwen-Coder — один из лучших" },
  { criterion: "Русский язык",      llama: "★★★",   mistral: "★★★★",  qwen: "★★★★★", note: "Qwen: 119+ языков с хорошей грамматикой" },
  { criterion: "Следование инструкциям", llama: "★★★★", mistral: "★★★★★", qwen: "★★★★", note: "Mistral — самый дисциплинированный" },
  { criterion: "Эффективность",     llama: "★★★★",  mistral: "★★★★★", qwen: "★★★★",  note: "Mixtral MoE — лучшее качество/размер" },
  { criterion: "Экосистема",        llama: "★★★★★", mistral: "★★★★",  qwen: "★★★",   note: "Llama = больше адаптеров и туториалов" },
  { criterion: "Лицензия",          llama: "Community", mistral: "Apache 2.0", qwen: "Apache 2.0", note: "Mistral и Qwen — максимум свободы" },
];

const inferenceTable = [
  { param: "Пропускная способность",  vllm: "Выше при высокой конкурентности (до 24× в пиковых сценариях)", tgi: "Хорошая; сильная сторона — длинные контексты (до 13× на промптах 200K+ токенов)" },
  { param: "Задержка (latency)",       vllm: "Стабильная, масштабируется линейно", tgi: "Ниже tail-latency при 1–2 пользователях" },
  { param: "API",                      vllm: "OpenAI-совместимый из коробки", tgi: "OpenAI-совместимый + SSE-стриминг" },
  { param: "Поддержка моделей",        vllm: "Широчайшая, новые архитектуры быстрее", tgi: "Все основные семейства, новые — сложнее" },
  { param: "Квантизация",             vllm: "AWQ, GPTQ, FP8", tgi: "GPTQ, bitsandbytes, EETQ, FP8" },
  { param: "Мониторинг",              vllm: "Базовый, требует доработки", tgi: "Prometheus + OpenTelemetry из коробки" },
  { param: "Простота запуска",         vllm: "pip install + одна команда", tgi: "Docker-контейнер, больше конфигурации" },
  { param: "Статус проекта",           vllm: "Активно развивается, де-факто стандарт", tgi: "Maintenance mode с декабря 2025" },
];

const hwTable = [
  { param: "GPU VRAM",     small: "6–8 ГБ (min), 24 ГБ (комфортно)", medium: "35–40 ГБ → 1× A100 80 ГБ", large: "140+ ГБ → 2× A100 80 ГБ" },
  { param: "RAM",          small: "32 ГБ",       medium: "64–128 ГБ",    large: "128–256 ГБ" },
  { param: "CPU",          small: "8+ ядер",      medium: "16–32 ядра",   large: "32+ ядра" },
  { param: "Диск",         small: "50 ГБ SSD",    medium: "150 ГБ NVMe",  large: "300+ ГБ NVMe" },
  { param: "Сеть",         small: "1 Gbps",       medium: "10 Gbps",      large: "10–25 Gbps (NVLink)" },
  { param: "Пользователи", small: "5–15",         medium: "20–50",        large: "50–100" },
  { param: "GPU (ориентир)", small: "RTX 4090 / A10G", medium: "1× A100 80 ГБ", large: "2× A100 / H100" },
];

const steps = [
  { num: "1", title: "Определите конкретный кейс", text: "Не «внедрить ИИ», а «сократить время подготовки ответа на тендерный запрос с 4 часов до 30 минут». Измеримая цель — основа адекватного пилота." },
  { num: "2", title: "Оцените данные", text: "Какие данные будет обрабатывать модель? Есть ли ПДн, КТ, гостайна? Нужно ли согласование с ИБ-службой? Какие требования к логированию?" },
  { num: "3", title: "Выберите модель и формат", text: "Для пилота — 7–8B в INT4. Достаточно, чтобы проверить гипотезу. Не начинайте с 70B: потратите месяцы на железо, а потом кейс может не сработать." },
  { num: "4", title: "Подготовьте инфраструктуру", text: "Выделите сервер с GPU. Убедитесь, что сетевая сегментация позволяет обращаться к сервису, но не даёт модели доступ в интернет." },
  { num: "5", title: "Разверните инференс-сервер", text: "vLLM + Docker — минимальная конфигурация с рабочим API за 30–60 минут. Проверьте endpoint, загрузку модели, стриминг." },
  { num: "6", title: "Интегрируйте с рабочим процессом", text: "RAG-пайплайн, чат-интерфейс, API-интеграция — подключите модель к реальной задаче. Здесь становится понятно, подходит модель или нет." },
  { num: "7", title: "Проведите валидацию", text: "Тестирование на реальных данных, замер метрик (точность, полнота, время ответа), сбор обратной связи от пользователей." },
  { num: "8", title: "Масштабируйте", text: "Переход в продакшен: мониторинг, алерты, процедуры обновления модели, регламент обработки инцидентов, документация." },
];

const mistakes = [
  { title: "Начинать с самой большой модели", text: "8B-модель часто справляется не хуже 70B. Проверьте гипотезу на малом — потом масштабируйте." },
  { title: "Выбирать по бенчмаркам, а не по задаче", text: "MMLU и HumanEval не покажут, как модель справится с суммаризацией ваших договоров на русском." },
  { title: "Игнорировать ИБ на старте", text: "Согласуйте архитектуру с ИБ-службой до развёртывания, а не после первого аудита." },
  { title: "Недооценивать эксплуатацию", text: "GPU потребляют ~300 Вт, модели нужно обновлять, сервис требует мониторинга. Закладывайте OpEx." },
  { title: "Не планировать замену моделей", text: "Архитектура должна позволять менять модель без переписывания интеграций. OpenAI-совместимый API решает это." },
  { title: "Путать пилот с продакшеном", text: "Ноутбук с RTX 4090 — это проверка гипотезы. Продакшен — сервер с резервированием, SLA и мониторингом." },
];
const relatedArticles = [
  { title: "On-premise LLM: как развернуть языковую модель внутри периметра", href: "/blog/02-on-premise-llm/", category: "Технологии", readTime: "12 мин" },
  { title: "Сравнение отечественных LLM: YandexGPT, GigaChat и альтернативы", href: "/blog/10-sravnenie-llm/", category: "Технологии", readTime: "12 мин" },
  { title: "Реестр доверенных ИИ-моделей в России: что уже известно", href: "/blog/08-reestr-doverennyh-ii-modelej-rossiya-2026/", category: "Регулирование", readTime: "12 мин" },
];
const faqItems = [
  {
    q: "Какую модель лучше брать для первого пилота в закрытом контуре?",
    a: "Обычно начинают с моделей 7–8B в INT4, чтобы быстро проверить бизнес-гипотезу без избыточных затрат на инфраструктуру.",
  },
  {
    q: "Что выбрать для инференса в новом проекте: vLLM или TGI?",
    a: "Для новых внедрений чаще выбирают vLLM из-за более активного развития и широкой поддержки моделей.",
  },
  {
    q: "Обязательно ли сразу покупать дорогой кластер GPU?",
    a: "Нет, для старта достаточно одного сервера под пилот, а масштабирование планируется после подтверждения результата.",
  },
];
---
<Base title="Как развернуть LLM в закрытом контуре: пошаговое руководство" description="Llama, Mistral или Qwen? Сравнение моделей, квантизация, vLLM vs TGI, требования к железу — полный гайд по развёртыванию LLM on-premise для ИБ-специалистов." articleDate="2026-04-03">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a,
      },
    })),
  })} />


      <section class="relative pt-28 pb-16 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent pointer-events-none"></div>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div>
            <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-accent transition-colors mb-8">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Назад к блогу
            </a>

            <div class="mb-6">
              <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-xs font-medium text-accent border border-white/10">
                Технологии
              </span>
            </div>

            <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6 leading-tight">
              Как развернуть LLM в закрытом контуре: пошаговое руководство
            </h1>

            <p class="text-xl text-muted-foreground mb-8 leading-relaxed">
              Llama, Mistral или Qwen? Сравнение моделей, квантизация, vLLM vs TGI, требования к железу — всё для ИБ-специалистов и технических руководителей.
            </p>

            <div class="flex items-center gap-6 text-sm text-muted-foreground pb-8 border-b border-white/10">
              <span class="flex items-center gap-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> 3 апреля 2026</span>
              <span class="flex items-center gap-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 10 мин чтения</span>
            </div>
          </div>
        </div>
      </section>

      
      <section class="pb-24">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="space-y-12 text-muted-foreground leading-relaxed text-[17px]">

            <!-- Лид -->
            <div>
              <p>
                Компания получает доступ к GPT-4 через API. Через два месяца выясняется, что сотрудники отправляли в промпты фрагменты конструкторской документации, персональные данные клиентов и тексты внутренних регламентов. Знакомая ситуация? Именно так обычно начинается разговор о развёртывании LLM on-premise — не с технического интереса, а с конкретного инцидента.
              </p>
              <p class="mt-4">
                Эта статья — практическое руководство для тех, кто уже решил, что локальная LLM для компании нужна, но пока не понимает, с какого конца подступиться. Разберём выбор модели, инфраструктуру, инструменты инференса и типовые ошибки — без рекламы и без иллюзий.
              </p>
            </div>


            <!-- ★ КАРТИНКА: Блок-схема архитектуры -->
            <div>
              <img
                src="/images/blog/07/llm-deploy-architecture.webp"
                alt="Архитектура развёртывания LLM в закрытом контуре: пользователь → API-gateway → vLLM → модель → ответ"
                class="w-full rounded-2xl object-cover"
              />
              <p class="text-sm text-muted-foreground/60 text-center mt-3 italic">
                Путь запроса в закрытом контуре: пользователь → API-gateway → vLLM → модель → ответ. Точки контроля ИБ выделены
              </p>
            </div>


            <!-- Секция 1: Почему не «просто поднять» -->
            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">
                  Почему «просто поднять модель на сервере» — не решение
                </h2>
              </div>

              <p>
                Интерес к LLM в закрытом контуре вырос не из-за моды. Причины практические: ужесточение требований регуляторов (152-ФЗ, отраслевые стандарты ИБ), рост стоимости облачных API при масштабировании, а также нежелание отдавать конфиденциальные данные третьей стороне — даже если эта сторона обещает их не хранить.
              </p>
              <p class="mt-4">
                Но между решением «нам нужна своя LLM» и работающим сервисом лежит цепочка нетривиальных инженерных решений. Поставить Docker-контейнер с моделью — это не развёртывание. Это эксперимент. Развёртывание LLM on-premise — это когда модель устойчиво обслуживает пользователей, укладывается в бюджет по железу, не деградирует под нагрузкой и вписывается в ИБ-инфраструктуру: сегментация сети, логирование, контроль доступа.
              </p>

              <div class="mt-6 p-5 rounded-xl bg-accent/5 border border-accent/20">
                <p class="text-sm"><span class="text-white font-semibold">Когда закрытый контур оправдан:</span> данные не должны покидать периметр (ПДн, гостайна, КТ); регуляторные требования запрещают облако; нужна предсказуемость затрат; нужен полный контроль над поведением модели, включая файнтюнинг.</p>
                <p class="text-sm mt-2"><span class="text-white font-semibold">Когда избыточен:</span> задача — отвечать на типовые вопросы по публичной базе знаний, объём невелик. Облачный API будет дешевле и проще.</p>
              </div>
            </div>


            <!-- Секция 2: Задачи для закрытого контура -->
            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">
                  Какие задачи решают в закрытом контуре
                </h2>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {[
                  { task: "Суммаризация документов", desc: "Протоколы совещаний, договоры, техническая документация" },
                  { task: "Семантический поиск", desc: "RAG-пайплайн поверх внутренней базы знаний" },
                  { task: "Генерация черновиков", desc: "КП, письма, отчёты по шаблону" },
                  { task: "Классификация обращений", desc: "Заявки от клиентов, тикеты в HelpDesk" },
                  { task: "Ассистент разработчика", desc: "Автодополнение кода, ревью, работа с внутренними API" },
                  { task: "Анализ тендерной документации", desc: "Извлечение требований, сопоставление с каталогом" },
                ].map((item) => (
                  <div class="p-4 rounded-xl bg-white/[0.03] border border-white/10">
                    <div class="text-white font-medium mb-1">{item.task}</div>
                    <div class="text-sm text-muted-foreground/80">{item.desc}</div>
                  </div>
                ))}
              </div>

              <p class="mt-6">
                Ключевой критерий: данные чувствительны, объём запросов предсказуем, а требования к качеству ответов измеримы. Если задача размыта — «пусть ИИ нам что-нибудь полезное подскажет» — пилот почти гарантированно провалится вне зависимости от модели.
              </p>
            </div>


            <!-- Секция 3: Выбор модели -->
            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                </div>
                <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">
                  Как выбрать модель: Llama, Mistral или Qwen
                </h2>
              </div>

              <p>
                Выбор модели — решение, на которое тратят больше всего времени. И часто зря, потому что выбирают по бенчмаркам, а не по реальным требованиям задачи. Разберём три наиболее зрелых семейства open-source LLM для on-premise.
              </p>

              <div class="mt-6 space-y-4">
                {[
                  {
                    name: "Llama 3.x / 4 (Meta AI)",
                    sizes: "8B – 405B (dense); Scout / Maverick (MoE)",
                    pros: "Стабильно высокое качество, крупнейшая экосистема адаптеров, максимальная поддержка во всех фреймворках. Огромное сообщество — любая проблема уже решена на GitHub.",
                    cons: "Русский язык из коробки средний — приемлемо для классификации, слабее в генерации связного текста.",
                    best: "Универсальный выбор, когда приоритет — стабильность и сообщество"
                  },
                  {
                    name: "Mistral / Mixtral (Mistral AI)",
                    sizes: "7B, 8×7B, 8×22B, Small, Large",
                    pros: "Отличное следование инструкциям — самый «дисциплинированный» из тройки. Mixtral MoE даёт качество 70B-модели при активации лишь 12.9B параметров. Лицензия Apache 2.0.",
                    cons: "Русский лучше Llama, но хуже Qwen. Крупные модели требуют больше VRAM, чем аналоги.",
                    best: "Многоязычность, точное следование инструкциям, работа с длинными документами"
                  },
                  {
                    name: "Qwen 2.5 / 3.x (Alibaba Cloud)",
                    sizes: "0.5B – 72B (dense); MoE до 235B+",
                    pros: "Лидер по мультиязычности — 119+ языков с хорошей грамматикой, включая русский. Qwen-Coder конкурирует с лучшими в генерации кода. Лицензия Apache 2.0.",
                    cons: "Экосистема и туториалы менее зрелые, чем у Llama.",
                    best: "Русский язык, код, структурированные данные, математика"
                  },
                ].map((m) => (
                  <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/10">
                    <h3 class="text-white font-bold text-lg mb-1">{m.name}</h3>
                    <p class="text-xs text-muted-foreground/60 mb-3">Размеры: {m.sizes}</p>
                    <p class="text-sm leading-relaxed mb-2"><span class="text-green-400">+</span> {m.pros}</p>
                    <p class="text-sm leading-relaxed mb-2"><span class="text-red-400">−</span> {m.cons}</p>
                    <p class="text-sm leading-relaxed"><span class="text-accent">→</span> <span class="text-white/80">{m.best}</span></p>
                  </div>
                ))}
              </div>

              <!-- Таблица сравнения моделей -->
              <div class="mt-8 overflow-x-auto rounded-2xl border border-white/10">
                <table class="w-full text-sm">
                  <thead>
