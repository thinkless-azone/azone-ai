---
import Base from '../../layouts/Base.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';

const meta = {
  title: 'Сравнение отечественных LLM 2026: YandexGPT, GigaChat и альтернативы для бизнеса',
  description: 'Объективное сравнение YandexGPT, GigaChat, MTS AI и open-source моделей для корпоративного использования. Критерии выбора, цены, on-premise, RAG — практическое руководство.',
  date: '2026-04-07',
  author: 'AZONE-AI',
  image: '/images/blog/10/sravnenie-llm-cover.webp',
  tags: ['LLM', 'YandexGPT', 'GigaChat', 'on-premise', 'RAG', 'сравнение моделей', 'корпоративный ИИ'],
};

const comparisonTable = [
  { criterion: "Русский язык", yandex: "Высокий", giga: "Высокий", mts: "Средний–Высокий", oss: "Зависит от модели" },
  { criterion: "Контекстное окно", yandex: "До 32K (Pro)", giga: "128K токенов", mts: "Зависит от модели", oss: "Зависит от модели" },
  { criterion: "Мультимодальность", yandex: "Текст, эмбеддинги", giga: "Текст, изображения, аудио, видео", mts: "Текст, речь", oss: "Зависит от модели" },
  { criterion: "API-совместимость", yandex: "OpenAI-совместимый", giga: "Собственный формат", mts: "REST API", oss: "OpenAI-совместимый (vLLM)" },
  { criterion: "On-premise", yandex: "Только Lite (open-source)", giga: "Ultra (открытые веса)", mts: "Через MWS Cloud", oss: "Полный контроль" },
  { criterion: "Данные в РФ", yandex: "Да (Yandex Cloud)", giga: "Да (инфраструктура Сбера)", mts: "Да (ЦОД МТС)", oss: "Да (ваша инфраструктура)" },
  { criterion: "Стоимость API (1 млн токенов)", yandex: "~800 ₽ (Pro 5.1)", giga: "~650 ₽ (Max)", mts: "Индивидуально", oss: "Стоимость GPU" },
  { criterion: "Дообучение", yandex: "Через Yandex Cloud", giga: "Через SberDevices", mts: "Через MWS", oss: "Полный контроль" },
];

const scenarios = [
  { icon: "💬", title: "AI-ассистент для сотрудников", models: "GigaChat 2 Lite / YandexGPT Lite", desc: "Чат-бот по HR, ИТ, черновики документов. Ключевое — скорость и стоимость на потоке." },
  { icon: "🔍", title: "Семантический поиск (RAG)", models: "YandexGPT + эмбеддинги / GigaChat Max / Qwen3 on-prem", desc: "Поиск по базе знаний, регламентам. Критичны: эмбеддинги, контекстное окно, точность." },
  { icon: "📧", title: "Обработка обращений и писем", models: "GigaChat 2 Lite / YandexGPT Lite", desc: "Классификация, маршрутизация, черновики ответов. Задача массовая, чувствительна к цене." },
  { icon: "📊", title: "Аналитика и суммаризация", models: "YandexGPT 5.1 Pro / GigaChat 2 Max", desc: "Договоры, протоколы, отчёты. Нужна «тяжёлая» модель с хорошим следованием инструкциям." },
  { icon: "🔒", title: "Закрытый контур", models: "GigaChat Ultra / Qwen3 / DeepSeek V3", desc: "Полная изоляция. Открытые веса, собственная GPU-инфраструктура." },
  { icon: "🛡️", title: "Повышенные требования ИБ", models: "Open-source (Qwen / Llama) на сертифицированном ПАК", desc: "Гостайна, конфиденциальные ПДн. Только on-premise с аттестацией, без телеметрии." },
];

const recommendations = [
  { task: "Массовые текстовые операции", model: "GigaChat 2 Lite", reason: "Лучшее соотношение цены и качества на русском" },
  { task: "Аналитика документов", model: "YandexGPT 5.1 Pro", reason: "Сильнее в следовании инструкциям и точности" },
  { task: "Закрытый контур", model: "GigaChat Ultra / Qwen3 / DeepSeek V3", reason: "Открытые веса, полный контроль" },
  { task: "Мультимодальные задачи", model: "GigaChat", reason: "Единственная отечественная платформа с такой широтой" },
  { task: "Речевая аналитика", model: "MTS AI (Audiogram + LLM)", reason: "Готовая интеграция транскрипции и суммаризации" },
  { task: "Максимальная независимость", model: "Open-source стек", reason: "Дороже в запуске, гибче в долгосрочной перспективе" },
];
const relatedArticles = [
  { title: "Как развернуть LLM в закрытом контуре: пошаговое руководство", href: "/blog/07-llm-closed-circuit-guide/", category: "Технологии", readTime: "10 мин" },
  { title: "On-premise LLM: как развернуть языковую модель внутри периметра", href: "/blog/02-on-premise-llm/", category: "Технологии", readTime: "12 мин" },
  { title: "Как ИИ сокращает время поиска документов с часов до минут", href: "/blog/03-azonedoc-case/", category: "Кейсы", readTime: "6 мин" },
];
const faqItems = [
  {
    q: "Какая LLM подходит для задач в закрытом контуре?",
    a: "Для закрытого контура обычно выбирают модели с открытыми весами и возможностью локального развёртывания на собственной инфраструктуре.",
  },
  {
    q: "Можно ли выбрать модель только по бенчмаркам?",
    a: "Нет, корректный выбор делается через пилот на ваших данных и сценариях, потому что бенчмарки не отражают специфику бизнеса.",
  },
  {
    q: "Что важнее при выборе: цена API или полная стоимость владения?",
    a: "Важнее общая стоимость владения: кроме токенов учитываются интеграция, инфраструктура, поддержка и требования ИБ.",
  },
];
---

<Base title={meta.title} description={meta.description} articleDate={meta.date} image={meta.image}>

  <!-- HERO -->
  <section class="relative pt-28 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div>
        <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-accent transition-colors mb-8">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Назад к блогу
        </a>
        <div class="mb-6 flex items-center gap-3 flex-wrap">
          {meta.tags.map((tag) => (
            <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-xs font-medium text-accent border border-white/10">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6 leading-tight">Сравнение отечественных LLM: YandexGPT, GigaChat и&nbsp;альтернативы</h1>
        <p class="text-xl text-muted-foreground mb-8 leading-relaxed">Объективное сравнение российских языковых моделей для корпоративного использования&nbsp;— критерии, цены, on&#8209;premise, RAG</p>
        <div class="flex items-center gap-6 text-sm text-muted-foreground pb-8 border-b border-white/10">
          <span class="flex items-center gap-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> 7 апреля 2026</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 12 мин чтения</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12 text-muted-foreground leading-relaxed text-[17px]">

        <!-- Лид -->
        <div class="space-y-4">
          <p>Ещё два года назад вопрос «какую языковую модель выбрать» для большинства российских компаний не&nbsp;стоял&nbsp;— ChatGPT казался единственным разумным вариантом. Сегодня ситуация принципиально иная.</p>
          <p>Санкционное давление, требования 152-ФЗ о&nbsp;локализации персональных данных, растущая настороженность регуляторов к&nbsp;трансграничной передаче информации&nbsp;— всё это превратило выбор LLM из&nbsp;технической задачи в&nbsp;стратегическое решение. Для компаний, работающих с&nbsp;государственными заказчиками, обрабатывающих персональные данные или оперирующих коммерческой тайной, использование зарубежных облачных моделей стало если не&nbsp;невозможным, то&nbsp;юридически рискованным.</p>
          <p>Параллельно российские вендоры за&nbsp;последние полтора года сделали заметный рывок. YandexGPT вышел на&nbsp;версию 5.1&nbsp;Pro, Сбер представил GigaChat Ultra с&nbsp;открытым кодом, а&nbsp;на&nbsp;рынке появились нишевые решения от&nbsp;MTS&nbsp;AI, Т-Банка и&nbsp;облачных провайдеров. Рынок перестал быть экспериментальным&nbsp;— пришло время прагматичного выбора.</p>
          <p>Эта статья&nbsp;— попытка дать ИТ-руководителю и&nbsp;бизнес-заказчику объективную картину: что реально умеют отечественные LLM, где их&nbsp;сильные и&nbsp;слабые стороны, и&nbsp;как выбирать модель не&nbsp;по&nbsp;маркетинговым обещаниям, а&nbsp;под конкретный корпоративный сценарий.</p>
        </div>

        <!-- Обложка -->
        <div>
          <img src="/images/blog/10/sravnenie-llm-cover.webp" alt="Сравнение отечественных LLM: YandexGPT, GigaChat и альтернативы — обложка статьи AZONE AI" class="w-full rounded-2xl object-cover" loading="eager" />
        </div>

        <!-- Почему нельзя выбирать по бренду -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Почему нельзя выбирать LLM «по&nbsp;громкости бренда»</h2>
          </div>
          <div class="space-y-4">
            <p>Демонстрация на&nbsp;конференции и&nbsp;работа в&nbsp;продакшене&nbsp;— два разных мира. Вендор показывает идеально подобранные промпты и&nbsp;заранее отрепетированные сценарии. В&nbsp;реальной корпоративной среде модель сталкивается с&nbsp;зашумлёнными данными, нечёткими инструкциями и&nbsp;пользователями, которые формулируют запросы далеко не&nbsp;так, как хотелось&nbsp;бы промпт-инженеру.</p>
          </div>
          <div class="mt-6 space-y-3">
            {[
              { title: "Бенчмарки ≠ качество в вашей задаче", text: "Когда вендор заявляет «превосходит GPT-4.1 в 56% случаев» — это результат на конкретной выборке. На вашем корпусе договоров результаты могут оказаться совершенно другими." },
              { title: "«Понимает русский» — слишком размыто", text: "Важно не абстрактное «понимание», а конкретные навыки: суммаризация юридического текста, извлечение реквизитов из договора, классификация обращений. Здесь разрыв между моделями существенный." },
              { title: "Облачный API и закрытый контур — разные продукты", text: "Модель через API может быть недоступна on-premise. А open-source версия того же вендора может заметно уступать проприетарной по качеству." },
            ].map((item) => (
              <div class="p-5 rounded-xl bg-white/[0.03] border border-white/10">
                <div class="flex items-start gap-3">
                  <span class="mt-0.5 shrink-0 w-5 h-5 text-red-400"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></span>
                  <div>
                    <div class="text-white font-bold text-sm mb-1">{item.title}</div>
                    <p class="text-sm leading-relaxed">{item.text}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-6 p-5 rounded-xl bg-green-500/5 border border-green-500/20">
            <p class="text-sm"><span class="text-green-400 font-semibold">Вывод. </span>Единственный надёжный способ выбора&nbsp;— пилотное тестирование на&nbsp;ваших данных и&nbsp;ваших задачах. Но&nbsp;чтобы сузить список кандидатов, нужно понимать архитектуру предложений на&nbsp;рынке.</p>
          </div>
        </div>

        <!-- Кого сравниваем -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Кого сравниваем: российские LLM в&nbsp;2026&nbsp;году</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {[
              { term: "YandexGPT", desc: "Семейство моделей Яндекса через Yandex Cloud AI Studio. Флагман — YandexGPT 5.1 Pro. Плюс Alice AI и YandexGPT 5 Lite в открытом доступе." },
              { term: "GigaChat", desc: "Модели Сбера 2-го поколения: Lite, Pro, Max. Флагман — GigaChat Ultra с открытым кодом. GigaChat 3 Ultra — MoE на 702 млрд параметров." },
              { term: "MTS AI / MWS GPT", desc: "Облачная B2B-платформа с агрегатором моделей. Интеграция с Audiogram для речевой аналитики. Инфраструктура ЦОД МТС." },
              { term: "Open-source on-premise", desc: "DeepSeek, Qwen, Llama, ruGPT, T-lite, GigaChat Ultra — на собственной инфраструктуре через vLLM, LangChain, векторные БД." },
            ].map((item) => (
              <div class="p-5 rounded-xl bg-white/[0.03] border border-white/10">
                <div class="text-lg font-bold text-accent mb-2">{item.term}</div>
                <p class="text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Критерии -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center shrink-0"><svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">8&nbsp;критериев объективного сравнения LLM для бизнеса</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              { num: "1", title: "Качество русского языка", text: "Деловой текст, терминология, правовой контекст" },
              { num: "2", title: "Работа с документами", text: "Суммаризация, классификация, длинный контекст" },
              { num: "3", title: "API и интеграция", text: "OpenAI-совместимость, SDK, function calling" },
              { num: "4", title: "Закрытый контур / on-premise", text: "Открытые веса, требования к GPU, дообучение" },
              { num: "5", title: "Безопасность и комплаенс", text: "152-ФЗ, локализация, политика вендора по данным" },
              { num: "6", title: "Стоимость владения", text: "Токены + инфраструктура + интеграция + дообучение" },
              { num: "7", title: "Масштабируемость", text: "Тысячи запросов в сутки, квоты, асинхронный режим" },
              { num: "8", title: "Ограничения и компромиссы", text: "Код, мультиязычность, агентные сценарии" },
            ].map((item) => (
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/10 flex items-start gap-3">
                <span class="w-7 h-7 rounded-full bg-accent/20 text-accent font-bold text-xs flex items-center justify-center shrink-0">{item.num}</span>
                <div>
                  <div class="text-white font-bold text-sm">{item.title}</div>
                  <div class="text-xs text-muted-foreground/70 mt-1">{item.text}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- YandexGPT -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-yellow-500/20 flex items-center justify-center shrink-0"><span class="text-yellow-400 font-bold text-lg">Y</span></div>
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">YandexGPT 5.1&nbsp;Pro</h2>
          </div>
          <h3 class="text-white font-semibold mt-4 mb-2">Сильные стороны</h3>
          <div class="space-y-4">
            <p>YandexGPT 5.1&nbsp;Pro на&nbsp;сегодняшний день&nbsp;— одна из&nbsp;наиболее сильных отечественных моделей для задач, связанных с&nbsp;текстом. Версия 5.1&nbsp;Pro значительно снизила частоту галлюцинаций и&nbsp;лучше следует системным промптам. Модель глубоко интегрирована в&nbsp;экосистему Yandex Cloud: AI&nbsp;Studio предоставляет удобную среду, OpenAI-совместимый API (с&nbsp;марта 2026), а&nbsp;эмбеддинг-модели позволяют строить RAG-пайплайны без сторонних компонентов.</p>
            <p>Для корпоративных клиентов важна связка с&nbsp;Яндекс&nbsp;360 для бизнеса: интеграция с&nbsp;почтой, документами и&nbsp;облачным хранилищем. В&nbsp;линейке есть YandexGPT Lite&nbsp;— быстрая и&nbsp;дешёвая, для массовых операций. YandexGPT&nbsp;5&nbsp;Lite выложена в&nbsp;открытый доступ на&nbsp;HuggingFace.</p>
          </div>
          <h3 class="text-white font-semibold mt-6 mb-2">Слабые стороны</h3>
          <div class="space-y-4">
            <p>По&nbsp;независимым тестам, модель иногда отказывается отвечать, ссылаясь на&nbsp;«отсутствие актуальных данных»&nbsp;— даже по&nbsp;устоявшимся темам. Может обрывать ответы при работе с&nbsp;длинными инструкциями. Полноценного on-premise для Pro-версии нет&nbsp;— доступ только через Yandex Cloud. Open-source Lite существенно уступает Pro. Стоимость Pro через API выше, чем у&nbsp;GigaChat.</p>
          </div>
          <div class="mt-6 p-5 rounded-xl bg-green-500/5 border border-green-500/20">
            <p class="text-sm"><span class="text-green-400 font-semibold">Где подходит. </span>Компании в&nbsp;экосистеме Yandex Cloud. Суммаризация русскоязычных текстов. RAG с&nbsp;эмбеддингами Яндекса. Быстрые пилоты через AI&nbsp;Studio.</p>
          </div>
          <div class="mt-3 p-5 rounded-xl bg-yellow-500/5 border border-yellow-500/20">
            <p class="text-sm"><span class="text-white font-semibold">Ограничения.</span> Не&nbsp;подходит для полностью изолированного контура (Pro недоступна on-premise). Для задач с&nbsp;кодом и&nbsp;сложным рассуждением уступает. Привязка к&nbsp;Yandex Cloud.</p>
          </div>
        </div>

        <!-- GigaChat -->
        <div>
          <div class="flex items-center gap-3 mb-5">
