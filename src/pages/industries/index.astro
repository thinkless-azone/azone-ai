---
import Base from '../../layouts/Base.astro';
import { industries } from '../../data/industries.js';
---
<Base
  title="ИИ для банков, ТЭК и госсектора"
  description="ИИ on-premise для банков, ТЭК и госсектора: закрытый контур, регуляторика, сценарии и пилот. AZONE-AI — внедрение без передачи данных в облако."
  image="/images/logo.png"
>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Отрасли AZONE-AI',
      description: 'ИИ on-premise для банков, ТЭК и госсектора.',
      url: 'https://azoneai.ru/industries/',
    })}
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: industries.map((industry, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `https://azoneai.ru/industries/${industry.id}/`,
        name: industry.name,
      })),
    })}
  />

  <section class="relative pt-24 pb-20 overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-accent transition-colors mb-12">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Назад на главную
      </a>
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-heading font-bold text-white mb-6">
          <span class="text-gradient">ИИ</span> для отраслей
        </h1>
        <p class="text-xl text-muted-foreground leading-relaxed max-w-3xl">
          У каждой отрасли — свои регуляторы, контуры данных и рабочие сценарии. Мы собрали посадочные страницы под банки,
          ТЭК и госсектор с привязкой к продуктам, услугам и материалам блога.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {industries.map((industry) => (
          <div class="glass-card p-8 h-full flex flex-col group hover:-translate-y-2 glow-border">
            <a href={`/industries/${industry.id}/`} class="block flex flex-col flex-1 min-h-0">
              <div class="flex justify-between items-start mb-6">
                <span class="text-sm font-bold text-accent">ОТРАСЛЬ {industry.number}</span>
                <span class="text-4xl font-heading font-bold text-white/10 group-hover:text-white/20 transition-colors">{industry.number}</span>
              </div>
              <h2 class="text-2xl font-bold text-white mb-3">{industry.name}</h2>
              <p class="text-muted-foreground text-sm mb-4 leading-relaxed line-clamp-3">{industry.heroLead}</p>
              <ul class="space-y-2 mb-6">
                {industry.scenarios.slice(0, 3).map((s) => (
                  <li class="flex items-start gap-2 text-xs text-muted-foreground">
                    <svg class="w-3 h-3 text-accent shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{s.title}</span>
                  </li>
                ))}
              </ul>
              <div class="flex items-center text-primary text-sm font-semibold group-hover:text-accent transition-colors mt-auto">
                Подробнее
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
