---
import Base from '../../layouts/Base.astro';
import { industries } from '../../data/industries.js';
import { products } from '../../data/products.js';
import { services } from '../../data/services.js';

export function getStaticPaths() {
  return industries.map((i) => ({ params: { id: i.id }, props: { industry: i } }));
}

const { industry } = Astro.props;
const industryFaq = industry.faq || [];
const contactBase = `/contact/?industry=${industry.id}&service=${industry.ctaService}`;

const relatedProductCards = industry.productMapping
  .map((m) => {
    const product = products.find((p) => p.id === m.productId);
    return product ? { product, why: m.why } : null;
  })
  .filter(Boolean);

const relatedServiceCards = industry.serviceMapping
  .map((sid) => services.find((s) => s.id === sid))
  .filter(Boolean);

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: industry.name,
  description: industry.pageDescription,
  url: `https://azoneai.ru/industries/${industry.id}/`,
  about: { '@type': 'Thing', name: `ИИ для отрасли: ${industry.name}` },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'B2B, B2G',
  },
  provider: {
    '@type': 'Organization',
    name: 'AZONE-AI',
    url: 'https://azoneai.ru',
  },
  hasPart: industry.relatedArticles.map((a) => ({
    '@type': 'Article',
    name: a.title,
    url: `https://azoneai.ru/blog/${a.slug}/`,
  })),
};
---

<Base
  title={industry.pageTitle}
  description={industry.pageDescription}
  breadcrumbTitle={industry.name}
  image={`/images/og/industry-${industry.id}.jpg`}
>

  <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)} />
  {industryFaq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: industryFaq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      })),
    })} />
  )}

  <!-- Hero -->
  <section class="relative pt-24 py-20 overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <a href="/industries/" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-accent transition-colors mb-12">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Назад к отраслям
      </a>
      <div class="max-w-4xl animate-fade-up">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white mb-6">
          <span class="font-heading font-medium tracking-wider">ОТРАСЛЬ {industry.number}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-heading font-bold text-white mb-6 leading-tight">
          {industry.h1.includes(industry.h1Gradient) ? (
            <>
              {industry.h1.split(industry.h1Gradient)[0]}
              <span class="text-gradient">{industry.h1Gradient}</span>
              {industry.h1.split(industry.h1Gradient)[1]}
            </>
          ) : (
            industry.h1
          )}
        </h1>
        <p class="text-xl md:text-2xl text-muted-foreground leading-relaxed mb-8 max-w-3xl">{industry.heroLead}</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${contactBase}&topic=pilot`} class="premium-btn">Обсудить пилот</a>
          <a
            href={`/contact/?industry=${industry.id}&topic=brief`}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-white/5 hover:bg-white/10 border border-white/10 transition-colors"
          >
            Получить отраслевой бриф
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Особенности отрасли</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {industry.problem.map((item) => (
          <div class="glass-card p-6 flex items-start gap-3">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-muted-foreground leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scenarios -->
  <section class="py-12 bg-black/20 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Сценарии применения ИИ</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {industry.scenarios.map((s) => (
          <div class="glass-card p-6">
            <h3 class="text-lg font-bold text-white mb-3">{s.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Constraints -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-4">Регуляторика и ограничения</h2>
      <p class="text-sm text-muted-foreground/70 mb-8 max-w-3xl leading-relaxed">
        Требования регулятора и внутренние процедуры уточняются по конкретной организации и объекту внедрения.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {industry.constraints.map((c) => (
          <div class="glass-card p-6 border-l-4 border-l-accent/50">
            <h3 class="text-base font-bold text-white mb-2">{c.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Primary article -->
  {industry.primaryArticle && (
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Основной материал</h2>
        <a
          href={`/blog/${industry.primaryArticle.slug}/`}
          class="glass-card glow-border overflow-hidden flex flex-col md:flex-row group hover:-translate-y-1 transition-transform"
        >
          <div class="md:w-2/5 shrink-0">
            <img
              src={industry.primaryArticle.coverImage}
              alt={industry.primaryArticle.title}
              class="w-full h-48 md:h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-8 md:p-10 flex flex-col justify-center flex-1">
            <span class="text-xs font-bold text-accent uppercase tracking-wider mb-3">Экспертная статья</span>
            <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent transition-colors">
              {industry.primaryArticle.title}
            </h3>
            <p class="text-muted-foreground leading-relaxed mb-6">{industry.primaryArticle.description}</p>
            <span class="inline-flex items-center gap-2 text-primary font-semibold group-hover:text-accent transition-colors">
              Читать полную статью
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Products -->
  {relatedProductCards.length > 0 && (
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Релевантные продукты</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedProductCards.map(({ product, why }) => (
            <a href={`/products/${product.id}/`} class="glass-card p-6 flex flex-col group hover:-translate-y-1 transition-transform h-full">
              <div
                class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-accent mb-4 group-hover:bg-primary/20 transition-colors"
                set:html={product.iconSvg}
              ></div>
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">{product.name}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed mb-3">{product.shortDesc}</p>
              <p class="text-xs text-muted-foreground/80 italic border-t border-white/10 pt-3 mt-auto">{why}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Services -->
  {relatedServiceCards.length > 0 && (
    <section class="py-12 bg-black/20 border-y border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Релевантные услуги</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedServiceCards.map((svc) => (
            <a href={`/services/${svc.id}/`} class="glass-card p-6 flex flex-col group hover:-translate-y-1 transition-transform h-full">
              <span class="text-xs font-bold text-accent mb-2">УСЛУГА {svc.number}</span>
              <h3 class="text-lg font-bold text-white mb-2 group-hover:text-accent transition-colors">{svc.name}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed flex-grow">{svc.heroLead}</p>
              <span class="mt-4 text-sm text-primary font-medium">Подробнее →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related articles -->
  {industry.relatedArticles.length > 0 && (
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Полезные материалы</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {industry.relatedArticles.map((article) => (
            <a href={`/blog/${article.slug}/`} class="glass-card p-6 flex flex-col group hover:-translate-y-1 transition-transform">
              <div class="text-white font-bold text-lg mb-2 group-hover:text-accent transition-colors">{article.title}</div>
              <p class="text-muted-foreground text-sm leading-relaxed flex-grow">{article.desc}</p>
              <div class="mt-4 text-sm text-primary font-medium">Читать →</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {industryFaq.length > 0 && (
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Частые вопросы</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {industryFaq.map((item) => (
            <div class="glass-card p-6">
              <h3 class="text-lg font-bold text-white mb-3">{item.question}</h3>
              <p class="text-muted-foreground leading-relaxed text-sm">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-3xl overflow-hidden border border-white/10">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-accent/20"></div>
        <div class="absolute inset-0 bg-background/40 backdrop-blur-xl"></div>
        <div class="relative p-10 md:p-16 text-center">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">
            Запросите расчёт пилота для {industry.name}
          </h2>
          <p class="text-lg text-muted-foreground mb-8 max-w-2xl mx-auto">
            Подготовим оценку сроков и формата внедрения с учётом регуляторики вашей отрасли.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 flex-wrap">
            <a href={`${contactBase}&topic=pilot`} class="premium-btn text-lg px-8 py-4">Обсудить пилот</a>
            <a href="/cases/" class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white bg-white/5 hover:bg-white/10 border border-white/10 transition-colors">
              Смотреть кейсы
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
