---
import Base from '../layouts/Base.astro';
---
<Base
  title="Страница не найдена"
  description="Запрошенная страница не существует или была перемещена. Перейдите на главную страницу AZONE-AI или воспользуйтесь навигацией по сайту."
  noindex={true}
>
  <div class="min-h-screen flex items-center justify-center pt-24">
    <div class="text-center">
      <h1 class="text-8xl font-heading font-bold text-white/20 mb-4">404</h1>
      <p class="text-xl text-muted-foreground mb-8">Страница не найдена</p>
      <a href="/" class="premium-btn">На главную</a>
    </div>
  </div>
</Base>
