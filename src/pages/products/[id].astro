---
import Base from '../../layouts/Base.astro';
import { products } from '../../data/products.js';

const productMaterials = {
  contentguard: [
    {
      href: '/blog/09-ii-v-informacionnoy-bezopasnosti-7-scenariev/',
      title: 'ИИ в информационной безопасности: 7 практических сценариев',
      desc: 'Практические сценарии применения ИИ в SOC, SIEM, DLP и смежных ИБ-процессах.',
    },
    {
      href: '/blog/01-cloud-ai-kii/',
      title: 'Почему облачный ИИ не подходит для КИИ и объектов с гостайной',
      desc: 'Разбор ограничений облачного AI для чувствительных инфраструктур и regulated-сред.',
    },
  ],
  azonedoc: [
    {
      href: '/blog/03-azonedoc-case/',
      title: 'Как ИИ сокращает время поиска документов с часов до минут',
      desc: 'Кейс внедрения интеллектуального архива и семантического поиска по документам.',
    },
    {
      href: '/blog/10-sravnenie-llm/',
      title: 'Сравнение отечественных LLM: YandexGPT, GigaChat и альтернативы',
      desc: 'Как выбирать корпоративную LLM для RAG, документооборота и аналитики.',
    },
  ],
  constructioneye: [
    {
      href: '/blog/04-construction-eye/',
      title: 'AI в строительстве: видеоаналитика для контроля безопасности',
      desc: 'Как компьютерное зрение помогает контролировать ТБ, СИЗ и ход работ на объекте.',
    },
    {
      href: '/blog/01-cloud-ai-kii/',
      title: 'Почему облачный ИИ не подходит для КИИ и объектов с гостайной',
      desc: 'Почему edge/on-premise подход критичен для объектов с повышенными требованиями к безопасности.',
    },
  ],
  predictmaintain: [
    {
      href: '/blog/05-predict-maintain/',
      title: 'Предиктивная аналитика: предотвращение аварий до их возникновения',
      desc: 'Разбор сценариев ML для телеметрии, оборудования и промышленной инфраструктуры.',
    },
    {
      href: '/blog/01-cloud-ai-kii/',
      title: 'Почему облачный ИИ не подходит для КИИ и объектов с гостайной',
      desc: 'Как требования к ИБ и локализации данных влияют на архитектуру промышленного AI.',
    },
  ],
  contractguard: [
    {
      href: '/blog/10-sravnenie-llm/',
      title: 'Сравнение отечественных LLM: YandexGPT, GigaChat и альтернативы',
      desc: 'Как подобрать модель для анализа документов, договоров и корпоративных знаний.',
    },
    {
      href: '/blog/07-llm-closed-circuit-guide/',
      title: 'Как развернуть LLM в закрытом контуре: пошаговое руководство',
      desc: 'Практический гид по выбору стека, железа и архитектуры для on-premise LLM.',
    },
  ],
};

export function getStaticPaths() {
  return products.map((p) => ({ params: { id: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const relatedMaterials = productMaterials[product.id] || [];
const productFaq = product.faq || [];
const softwareApplicationJsonLd = product.id === 'contractguard'
  ? {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ContractGuard",
      "description": "Доверенный ИИ-ассистент для автоматизации договорной работы в закрытом контуре.",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "LegalTech, AI Assistant",
      "operatingSystem": "Astra Linux, РЕД ОС, Windows Server",
      "url": "https://azoneai.ru/products/contractguard/",
      "featureList": [
        "Автоматическая проверка договоров",
        "Сравнение версий документов",
        "Генерация протоколов разногласий",
        "On-premise LLM в закрытом контуре",
        "Интеграция с Directum, Тезис, 1С"
      ],
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "seller": {
          "@type": "Organization",
          "name": "AZONE-AI",
          "url": "https://azoneai.ru"
        },
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "RUB"
        }
      },
      "provider": {
        "@type": "Organization",
        "name": "AZONE-AI",
        "url": "https://azoneai.ru"
      }
    }
  : {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": product.name,
      "description": product.seoDescription || product.shortDesc,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Linux, Windows Server",
      "url": `https://azoneai.ru/products/${product.id}/`,
      "featureList": product.benefits,
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "seller": { "@type": "Organization", "name": "AZONE-AI", "url": "https://azoneai.ru" },
        "priceSpecification": { "@type": "PriceSpecification", "priceCurrency": "RUB" }
      },
      "provider": { "@type": "Organization", "name": "AZONE-AI", "url": "https://azoneai.ru" }
    };
---
<Base
  title={product.seoTitle || product.name}
  description={product.seoDescription || product.shortDesc}
  breadcrumbTitle={product.name}
>

  <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationJsonLd)} />
  {productFaq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": productFaq.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })} />
  )}

  <!-- Hero -->
  <section class="relative pt-24 py-20 overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <a href="/products/" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-accent transition-colors mb-12">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Назад к продуктам
      </a>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-up">
          <div class="flex items-center gap-3 flex-wrap mb-6">
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white">
              <span class="text-accent" set:html={product.iconSvg}></span>
              <span class="font-heading font-medium tracking-wider">РАЗДЕЛ {product.number}</span>
            </div>
            {product.hasDemo && (
              <a href="#demo-block" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-500/20 border border-emerald-500/40 text-emerald-300 text-xs font-bold uppercase tracking-wider hover:bg-emerald-500/30 transition-colors">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Демо доступно
              </a>
            )}
          </div>
          <h1 class="text-4xl md:text-6xl font-heading font-bold text-white mb-6">{product.name}</h1>
          <p class={`text-xl md:text-2xl text-muted-foreground leading-relaxed ${product.heroLead ? 'mb-4' : 'mb-8'}`}>{product.shortDesc}</p>
          {product.heroLead && (
            <p class="text-lg text-muted-foreground/80 leading-relaxed mb-8 max-w-2xl">{product.heroLead}</p>
          )}
          <div class="flex flex-col sm:flex-row gap-3">
            <a href={`/contact/?product=${encodeURIComponent(product.name)}`} class="premium-btn">Обсудить внедрение</a>
            {product.hasDemo && (
              <a href={product.demoUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-emerald-300 bg-emerald-500/10 hover:bg-emerald-500/20 border border-emerald-500/30 transition-colors">
                Открыть демо
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            )}
          </div>
        </div>
        <div class="glass-card p-8 relative overflow-hidden animate-fade-up animate-delay-200">
          <h3 class="text-2xl font-bold text-white mb-6 relative z-10">Что делает</h3>
          <ul class="space-y-4 relative z-10">
            {product.fullDesc.map((item) => (
              <li class="flex items-start gap-3 text-muted-foreground">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Details -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-accent/20 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">Кому подходит</h3>
          <p class="text-muted-foreground leading-relaxed">{product.audienceDetail}</p>
        </div>
        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">Как поставляется</h3>
          <p class="text-muted-foreground leading-relaxed">{product.delivery}</p>
        </div>
        <div class="glass-card p-8 border-accent/30">
          <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-4">Стоимость</h3>
          <p class="text-muted-foreground leading-relaxed">{product.costDetail}</p>
        </div>
      </div>
    </div>
  </section>

  {product.roiMetrics?.length > 0 && (
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Экономический эффект</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {product.roiMetrics.map((metric) => (
            <div class={`glass-card p-6 border-l-4 ${metric.borderClass}`}>
              <div class={`text-4xl font-bold mb-2 ${metric.valueClass}`}>{metric.value}</div>
              <div class="text-white font-medium mb-2">{metric.title}</div>
              <p class="text-sm text-muted-foreground">{metric.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {productFaq.length > 0 && (
    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-8">Частые вопросы</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {productFaq.map((faq) => (
            <div class="glass-card p-6">
              <h3 class="text-lg font-bold text-white mb-3">{faq.question}</h3>
              <p class="text-muted-foreground leading-relaxed">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {product.hasDemo && (
    <section id="demo-block" class="pb-24 scroll-mt-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative rounded-3xl overflow-hidden border border-emerald-500/30">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 via-transparent to-cyan-500/10"></div>
          <div class="absolute inset-0 bg-background/40 backdrop-blur-xl"></div>
          <div class="relative p-8 md:p-12 lg:p-16">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">
              <div class="lg:col-span-3">
                <div class="flex items-center gap-3 mb-5">
                  <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center shrink-0">
                    <svg class="w-6 h-6 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </div>
                  <span class="inline-block px-2.5 py-0.5 rounded-full bg-emerald-500/20 border border-emerald-500/40 text-emerald-300 text-[10px] font-bold uppercase tracking-wider">Демо-доступ</span>
                </div>

                <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-5">Попробуйте {product.name} в&nbsp;работе</h2>

                <p class="text-lg text-muted-foreground mb-6 leading-relaxed">
                  Демо-стенд работает на&nbsp;синтетических данных и&nbsp;показывает реальные сценарии работы системы&nbsp;— от&nbsp;дашборда событий до&nbsp;аналитики и&nbsp;отчётов. Доступ открытый, можно зайти прямо сейчас.
                </p>

                {product.demoNote && (
                  <p class="text-sm text-muted-foreground/80 mb-8 italic leading-relaxed">
                    {product.demoNote}
                  </p>
                )}

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
                  <div class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-sm">Все ключевые сценарии</span>
                  </div>
                  <div class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-sm">Только синтетические данные</span>
                  </div>
                  <div class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-sm">Доступ за&nbsp;секунды</span>
                  </div>
                </div>
              </div>

              <div class="lg:col-span-2">
                <div class="rounded-2xl bg-background/60 backdrop-blur-sm border border-white/10 p-6">
                  <div class="text-xs font-bold uppercase tracking-wider text-emerald-300 mb-4">Демо-доступ</div>

                  <div class="space-y-3 mb-6">
                    <div class="flex items-center justify-between gap-4 px-3 py-2.5 rounded-lg bg-white/5 border border-white/10">
                      <span class="text-sm text-muted-foreground">Логин</span>
                      <code class="text-sm font-mono text-white font-bold">{product.demoLogin}</code>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-3 py-2.5 rounded-lg bg-white/5 border border-white/10">
                      <span class="text-sm text-muted-foreground">Пароль</span>
                      <code class="text-sm font-mono text-white font-bold">{product.demoPassword}</code>
                    </div>
                  </div>

                  <a href={product.demoUrl} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full px-6 py-3 rounded-xl font-semibold bg-emerald-500 hover:bg-emerald-400 text-background transition-colors">
                    Открыть {product.name}
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>

                  <p class="text-xs text-muted-foreground/70 text-center mt-4">
                    Откроется в&nbsp;новой вкладке
                  </p>
                </div>

                <a href={`/contact/?product=${encodeURIComponent(product.name)}&topic=demo`} class="block mt-4 text-center text-sm text-emerald-300 hover:text-emerald-200 transition-colors">
                  Хотите персональную демонстрацию с&nbsp;инженером? →
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {relatedMaterials.length > 0 && (
    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white">Полезные материалы</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {relatedMaterials.map((item) => (
            <a href={item.href} class="glass-card p-6 flex flex-col group hover:-translate-y-1">
              <div class="text-white font-bold text-xl mb-3 group-hover:text-accent transition-colors">{item.title}</div>
              <p class="text-muted-foreground leading-relaxed flex-grow">{item.desc}</p>
              <div class="mt-6 inline-flex items-center text-sm font-semibold text-primary group-hover:text-accent transition-colors">
                Читать материал
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-24 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="relative rounded-3xl overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-accent/20"></div>
        <div class="absolute inset-0 bg-background/40 backdrop-blur-xl"></div>
        <div class="absolute inset-0 border border-white/10 rounded-3xl"></div>
        <div class="relative p-10 md:p-16 text-center">
          <h2 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6">Начните с <span class="text-gradient">пилотного проекта</span></h2>
          <p class="text-lg text-muted-foreground mb-10 max-w-2xl mx-auto">За 4–8 недель мы развернём решение на вашей инфраструктуре.</p>
          <a href="/contact/?product=other" class="premium-btn text-lg px-8 py-4">Обсудить пилот</a>
        </div>
      </div>
    </div>
  </section>
</Base>
